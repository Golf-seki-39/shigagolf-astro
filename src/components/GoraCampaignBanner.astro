---
// 共通バナーコンポーネント：GoraCampaignBanner.astro
// 各記事の「楽天GORA予約ボタン」の直下に配置してください。
const targetUrl = "/articles/rakuten-gora-point-guide/";
---
<div class="not-prose my-10 p-6 bg-slate-50 border-2 border-green-600 rounded-xl shadow-md">
    <div class="flex items-center gap-2 mb-3">
        <span class="text-2xl">⛳️</span>
        <h3 class="text-lg md:text-xl font-bold text-green-800 m-0">
            楽天GORAで予約する前に3分だけ確認！
        </h3>
    </div>

    <p class="text-slate-700 text-sm md:text-base leading-relaxed mb-4">
        初めて楽天GORAを利用する方は、キャンペーンを活用することで
        <strong>3,000〜19,000ポイント獲得できる可能性があります。</strong><br>
        予約ボタンを押す前に、一度だけ確認してみてください。
    </p>

    <a href={targetUrl} class="flex items-center justify-center w-full md:w-auto px-6 py-3 bg-green-600 text-white font-bold rounded-lg hover:bg-green-700 transition-colors duration-200 text-base no-underline shadow-sm">
        損しない予約手順を見る ＞
    </a>
