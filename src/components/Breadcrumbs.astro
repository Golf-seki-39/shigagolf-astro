---
// src/components/Breadcrumbs.astro

// --- Props ---
// BaseLayoutからページの <title> と、親ハブ記事の情報（あれば）を受け取ります
// ★追加: parentHub を受け取る
const { pageTitle, parentHub } = Astro.props;

// --- 静的パス名の日本語マッピング ---
const pathTranslations = new Map([
    ["articles", "お役立ち記事"],
    ["category", "カテゴリ"],
    ["comparison", "比較記事"],
    ["review", "体験レビュー"],
    ["ranges", "練習場詳細"],
    ["contact", "お問い合わせ"],
    ["about", "シガゴルについて"],
    ["criteria", "評価基準"],
    ["map", "マップ"],
    ["adogawa-sc-review", "安曇川スポーツセンター"],
    ["azuchi-review", "安土ゴルフ練習場"],
    ["ksp-hikone-review", "KSP彦根"],
    ["ksp_hope-review", "KSP希望ヶ丘"],
]);

const segmentsToIgnore = new Set([
    "ranges", 
    "review", 
    "category", 
    "comparison", 
    "adogawa-sc-review", 
]);

// --- パンクズリストの生成ロジック ---
const currentPath = Astro.url.pathname;
const breadcrumbs = [];

// 1. ホームを追加
breadcrumbs.push({ name: "ホーム", href: "/" });

// 2. パスを解析して動的にパンクズを追加
if (currentPath !== "/") {
    const segments = currentPath.split("/").filter(Boolean);
    let pathAccumulator = ""; 

    segments.forEach((segment, index) => {
        if (segmentsToIgnore.has(segment)) {
            pathAccumulator += `/${segment}`;
            return; 
        }
        pathAccumulator += `/${segment}`;
        const isLast = index === segments.length - 1;
        let name = "";

        if (isLast) {
            // ▼▼▼【ここが最大の変更点！】▼▼▼
            // もし現在のページが最後であり、かつ「親ハブ記事（parentHub）」の情報が渡されていれば、
            // 現在のページを描画する【直前】に、親ハブ記事をパンくずの間に挟み込む
            if (parentHub) {
                breadcrumbs.push({
                    name: parentHub.name,
                    href: parentHub.href
                });
            }
            // ▲▲▲--------------------▲▲▲

            if (pageTitle) {
                const titlePart = pageTitle.split(" | ")[0];
                name = titlePart
                    .replace("の口コミ・評判", "")
                    .replace("のレビュー", "");
            } else {
                name = pathTranslations.get(segment) || segment;
            }
        } else {
            name = pathTranslations.get(segment) || segment;
        }

        breadcrumbs.push({
            name: name,
            href: isLast ? null : pathAccumulator,
        });
    });
}

// --- SEO用 JSON-LD 構造化データの生成 ---
// 間に挟み込んだ親ハブ記事も自動的に構造化データに反映されます！
const jsonLdItems = breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    ...(item.href && { item: new URL(item.href, Astro.site).href }),
}));

const ldJson = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: jsonLdItems,
};
---

{/* --- HTMLのレンダリング --- */}
{
    breadcrumbs.length > 1 && (
        <nav
            aria-label="パンクズリスト"
            class="container mx-auto px-4 py-3 text-sm text-slate-600"
        >
            <ol class="flex flex-wrap gap-x-2">
                {breadcrumbs.map((crumb, index) => (
                    <li class="flex items-center gap-x-2">
                        {index > 0 && (
                            <span class="text-slate-400" aria-hidden="true">
                                ›
                            </span>
                        )}
                        {crumb.href ? (
                            <a
                                href={crumb.href}
                                class="hover:underline hover:text-green-700 font-medium"
                            >
                                {crumb.name}
                            </a>
                        ) : (
                            <span
                                class="font-bold text-slate-800"
                                aria-current="page"
                            >
                                {crumb.name}
                            </span>
                        )}
                    </li>
                ))}
            </ol>
        </nav>
    )
}

<script type="application/ld+json" set:html={JSON.stringify(ldJson)} />