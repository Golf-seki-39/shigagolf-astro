    <style>
        .map-container {
            position: relative;
            width: 100%;
            overflow: hidden;
            padding-top: 56.25%; /* 16:9 aspect ratio for responsive iframe */
        }
        .map-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }
        .scroll-mt-24 {
            scroll-margin-top: 6rem; /* 96px */
        }
        .summary-box {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }
    </style>

    <script define:vars={{ priceData }}>
        document.addEventListener('DOMContentLoaded', () => {
            const dayRadios = document.querySelectorAll('input[name="sim-day"]');
            const floorRadios = document.querySelectorAll('input[name="sim-floor"]');
            const durationSelect = document.getElementById('sim-duration');
            const priceDisplay = document.getElementById('sim-total-price');

            function calculate() {
                const day = document.querySelector('input[name="sim-day"]:checked').value;
                const floor = document.querySelector('input[name="sim-floor"]:checked').value;
                const duration = durationSelect.value;

                let price = 0;
                // 石山は入場料無料なので、純粋な打ち放題料金のみ計算
                if (priceData.uchihodai[day] && priceData.uchihodai[day][floor]) {
                    price = priceData.uchihodai[day][floor][duration];
                }

                if (price) {
                    priceDisplay.textContent = price.toLocaleString();
                } else {
                    priceDisplay.textContent = '----';
                }
            }

            // イベントリスナーの登録
            dayRadios.forEach(r => r.addEventListener('change', calculate));
            floorRadios.forEach(r => r.addEventListener('change', calculate));
            durationSelect.addEventListener('change', calculate);

            // 初回計算
            calculate();
        });
    </script>
</BaseLayout>