---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

// --- 共通コンポーネントをインポート ---
import MySlider from '../../../components/MySlider.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';

// --- This article's specific information ---
// 🔥 リライト：検索ユーザーが一番知りたい「料金・混雑・お得情報」をタイトルに配置
const title = "【KSP彦根】料金や混雑状況を徹底レビュー！ふるさと納税で実質タダになる裏ワザも | シガゴル";
// 🔥 リライト：検索結果でクリックしたくなるようにメリットを強調
const description = "滋賀県の「KSP彦根」を初心者ゴルファーが徹底体験レビュー！全打席無料のトップトレーサーの使い心地、混雑しやすい時間帯、そして楽天ふるさと納税を使って料金を劇的に安くする裏ワザまで大公開。270ヤードの圧倒的開放感を味わおう！";
const category = "体験談";
const pubDate = "2025-06-05";
const pubDateISO = "2025-06-05T10:00:00+09:00";
// 🔥 リライトした今日の日付を更新日にセットしてSEO効果を上げる（YYYY-MM-DD形式に変更してください）
const updatedDate = "2026-05-20"; 
const imageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6889.jpg"; // アイキャッチを広々とした270Yの画像に変更
const rangeId = "ksp_hikone";
// --- End of specific information ---

// --- シェアボタンと構造化データ用の変数を定義 ---
const baseUrl = "https://shigolf.com";
const articleUrl = `${baseUrl}/articles/ksp-hikone-review/`;
const headline = title.split(" | ")[0];

const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const docPath = `artifacts/${appId}/public/data/practice_ranges/${rangeId}`;
const docRef = doc(db, docPath);
const docSnap = await getDoc(docRef);
let rangeData = null;
if (docSnap.exists()) {
    rangeData = docSnap.data();
} else {
    console.error(`Error: No document found for rangeId: ${rangeId}`);
}

// --- [4] 関連記事リストの定義 ---
const experienceReports = [
    { url: '/articles/taga-golf/', title: '多賀ゴルフ練習場 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/taga_gr/gallery/aikyatti-taga.png' },
    { url: '/articles/review/365hikone/', title: '365ゴルフクラブ 彦根 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/365_hikone/gallery/0000img.jpg' },
    { url: '/articles/ksp-hikone-review/', title: 'KSP彦根 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6889.jpg' },
    { url: '/articles/ksp_hope-review/', title: 'KSP希望ヶ丘 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hope/gallery/000000img.png' },
];

const comparisonArticles = [
    { url: '/articles/hikone-tracker/', title: '【彦根】弾道測定器が無料のゴルフ練習場まとめ', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/ai-hikonetore-sa-.jpg' },
    // 🔥 料金シミュレーター記事へのリンクを最新のものに変更
    { url: '/articles/hikone-price-comparison/', title: '【彦根・多賀】打ちっぱなし料金比較シミュレーター', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/hikone-price.png' }, 
];
---

<BaseLayout title={title} description={description} pubDate={pubDate} updatedDate={updatedDate} ogImage={imageUrl}>

    <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    {
        "@context": "https://schema.org",
        "@type": "Article",
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": articleUrl
        },
        "headline": headline,
        "description": description,
        "image": [ 
            imageUrl,
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6506.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6697.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6513.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6702.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6517.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6527.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6624 2.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6688.png",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6889.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6521.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6525.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6512.png",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6537.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6545.jpg",
            "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6539.jpg"
        ],
        "author": {
            "@type": "Person",
            "name": "関（せき）",
            "url": "https://shigagolf.com/about/",
            "image": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/author.png",
            "sameAs": [ "https://x.com/Golf_Seki39", "https://golf-medley.com/articles/authors/seki", "https://note.com/seki_golf_39", "https://www.tiktok.com/@user2579514551181" ]
        },
        "publisher": {
            "@type": "Organization",
            "name": "シガゴル",
            "logo": { "@type": "ImageObject", "url": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/logo.png" }
        },
        "datePublished": pubDateISO,
        "dateModified": updatedDate ? `${updatedDate}T10:00:00+09:00` : pubDateISO
    },
    {
        "@context": "https://schema.org",
        "@type": "Review",
        "itemReviewed": {
            "@type": "LocalBusiness",
            "name": rangeData?.name,
            "image": rangeData?.imageUrl,
            "telephone": rangeData?.phone,
            "priceRange": rangeData?.priceRange,
            "address": {
                "@type": "PostalAddress",
                "streetAddress": rangeData?.address,
                "addressLocality": rangeData?.city,
                "addressRegion": "滋賀県",
                "postalCode": rangeData?.postalCode,
                "addressCountry": "JP"
            }
        },
        "reviewRating": {
            "@type": "Rating",
            "ratingValue": Number(rangeData?.avgRating) || 3,
            "bestRating": "5",
            "worstRating": "1"
        },
        "author": { "@type": "Person", "name": "関（せき）" }
    }
])} />
    
    <div
        id="article-ksp-hikone-review-view"
        class="bg-white p-6 md:p-8 rounded-lg shadow-lg max-w-4xl mx-auto"
    >
        <a
            href="/articles/"
            class="nav-link back-button mb-6 text-green-700 font-semibold hover:underline"
            >‹ お役立ち記事一覧に戻る</a
        >

        <article
            class="prose lg:prose-xl max-w-none text-slate-700 leading-relaxed"
        >
            <header>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-800 leading-tight">{headline}</h1>
                <div class="text-sm text-slate-500 mt-3 flex flex-wrap items-center gap-x-4 gap-y-2">
                    <span>公開日：{pubDate}</span>
                    
                    {updatedDate && (
                        <span class="flex items-center gap-1 text-slate-600 font-semibold bg-slate-100 px-2 py-1 rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                            更新日：{updatedDate}
                        </span>
                    )}
                </div>
            </header>

            <Image
                src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6889.jpg"
                alt="270ヤードの開放感！KSP彦根"
                class="w-full h-auto object-cover rounded-lg my-8 shadow-md"
                loading="eager"
                fetchpriority="high"
                width={1200}
                height={800}
                format="webp"
                quality={80}
            />

            <p>
                「自分のショット、本当は何ヤード飛んでるの？」「もっと効率よく上手くなりたいけど、何から始めれば…？」
            </p>
            <p>
                ゴルフは感覚も大切ですが、自分のショットが「データで見える化」されたら、練習がもっと楽しく、効率よく上達できそうだと思いませんか？
            </p>
            <p>
                滋賀県彦根市にある「KSP彦根」は、まさにそんな願いを叶えてくれる、ちょっと未来的なゴルフ練習場です。私がこの練習場に惹かれる最大の理由は、全打席に標準装備された「トップトレーサー・レンジ」。そして、270ヤードの圧倒的な開放感です。
            </p>
            <p>
                今回は、ハイテク設備と安心システムが融合した「KSP彦根」の魅力や料金システム、気になる混雑状況、さらには<strong>「ふるさと納税で実質タダで練習する裏ワザ」</strong>まで、私の体験を交えながら徹底的にご紹介します！
            </p>

            <div
                class="toc-container bg-slate-50 p-6 rounded-lg border border-slate-200 my-8 not-prose"
            >
                <h2 class="text-xl font-bold mb-4 text-slate-800">
                    この記事の目次
                </h2>
                <ul class="space-y-2 list-disc list-inside">
                    <li><a href="#about-ksp" class="text-green-700 hover:underline">KSP彦根ってどんなところ？</a></li>
                    <li><a href="#driving-range" class="text-green-700 hover:underline">【環境＆料金】270ヤードの開放感と料金システム</a></li>
                    <li><a href="#furusato" class="text-green-700 hover:underline text-red-600 font-bold">🉐【必見】ふるさと納税で実質タダになる裏ワザ</a></li>
                    <li><a href="#toptracer" class="text-green-700 hover:underline">【設備】全打席トップトレーサーが無料！</a></li>
                    <li><a href="#ic-card" class="text-green-700 hover:underline">【システム】失くしても安心なICカード</a></li>
                    <li><a href="#facility-info" class="text-green-700 hover:underline">トイレ事情や混雑状況など</a></li>
                </ul>
            </div>

            <div class="not-prose my-10 p-6 bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-xl shadow-sm">
                <div class="flex items-center gap-2 mb-3">
                    <span class="text-2xl">💰</span>
                    <p class="font-bold text-amber-900 text-lg m-0">彦根エリアで一番「安い」練習場はどこ？</p>
                </div>
                <p class="text-sm text-slate-700 mb-5 leading-relaxed">
                    KSP彦根に行く前にチェック！彦根・多賀エリアの練習場の複雑な料金システムを徹底比較しました。あなたの条件を選ぶだけで<strong>「一番安い施設とプラン」が1秒でわかる自動計算シミュレーター</strong>を公開中です！
                </p>
                <a href="/articles/hikone-price-comparison/" class="flex items-center justify-center w-full md:w-auto px-6 py-3 bg-amber-600 text-white font-bold rounded-full hover:bg-amber-700 hover:shadow-md transition-all duration-200 no-underline text-sm md:text-base">
                    【1秒判定】料金比較シミュレーターを使ってみる ＞
                </a>
            </div>

            <h2
                id="about-ksp"
                class="scroll-mt-24 text-2xl md:text-3xl font-bold text-slate-800 mt-12 mb-4 border-b-2 border-green-500 pb-2"
            >
                KSP彦根ってどんなところ？〜最新技術と安心システムの融合〜
            </h2>
            <Image
                src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6506.jpg"
                alt="KSP彦根のエントランス＿一部屋根もあり雨の日も安心"
                class="w-full h-auto object-cover rounded-lg my-6"
                loading="lazy"
                width={1200}
                height={800}
                format="webp"
                quality={80}
            />
            <p>
                KSP彦根は、滋賀県彦根市にある、最新技術と安心のシステムでゴルファーの上達をスマートにサポートしてくれる大型ゴルフ練習場です。
            </p>
            <p>
                その最大の魅力は、なんといっても全打席に無料で使える「トップトレーサー・レンジ」が備わっていること！そして、利用者を考えた便利なICシステムや、圧倒的な広さが人気の理由です。
            </p>

            <h2
                id="driving-range"
                class="scroll-mt-24 text-2xl md:text-3xl font-bold text-slate-800 mt-12 mb-4 border-b-2 border-green-500 pb-2"
            >
                【環境＆料金】270ヤードの開放感と選べる料金プラン
            </h2>
            <p>
                KSP彦根のドライビングレンジは、奥行きなんと<strong>270ヤード！</strong>開放感たっぷりで、思いっきりドライバーを振り抜けます。
            </p>
            <p>
                打席は1階・2階合わせて全80打席と十分な数があり、そのうち左利き用打席も6打席用意されています。駐車場も約95台分と広いです。
            </p>

            <h3 class="text-xl md:text-2xl font-semibold text-slate-800 mt-8 mb-3">
                ✅ 選べる料金システム（単価打ち・打ち放題）
            </h3>
             <Image
                src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6374.jpg"
                alt="KSP彦根の料金表"
                class="w-full h-auto object-cover rounded-lg my-6"
                loading="lazy"
                width={1200}
                height={800}
                format="webp"
                quality={80}
            />
            <p>
                自分の練習時間や目的に合わせて、1球単価と時間貸し（打ち放題）を選べます。じっくりアプローチを打ち込みたい時、ドライバーでたくさん球数を打ちたい時など、状況に合わせて選べるのが嬉しいポイント。
            </p>
            <p>
                さらに、<strong>女性と中学生以下は指定時間帯が優待単価（6.6円〜7.7円）</strong>になるなど、初心者や家族連れにも優しい料金設定になっています！
            </p>

            <h2
                id="furusato"
                class="scroll-mt-24 text-2xl md:text-3xl font-bold text-slate-800 mt-12 mb-6 border-b-2 border-red-500 pb-2 flex items-center"
            >
                <span class="text-3xl mr-2">🉐</span>【必見】ふるさと納税で実質タダになる裏ワザ
            </h2>
            <p>
                KSPで練習するなら、絶対に知っておくべき最強のお得情報があります。それが<strong>「ふるさと納税」の活用</strong>です。
            </p>
            
            <div class="not-prose bg-blue-50 p-5 md:p-6 rounded-lg border-2 border-blue-300 mb-8 text-center shadow-sm">
                <p class="text-sm text-slate-700 mb-5 text-left leading-relaxed">
                    KSPのICカードはふるさと納税の返礼品になっています。楽天ふるさと納税を経由すれば、<strong>寄付額の30%が練習場のICカードポイントとして直接還元されます！</strong>（例：1万円の寄付で3,000円分の練習ポイント付与）。税金対策をしながら練習代を浮かせられる、まさに錬金術です。<br>
                    <span class="text-xs text-red-600 font-bold mt-2 inline-block">※リンク先は野洲市（KSP希望ヶ丘）の返礼品ですが、KSPは全店共通ICカードのため彦根店でも全く問題なく利用可能です。（私自身、1枚のカードで両店舗を利用しています！）</span>
                </p>
                <a href="https://a.r10.to/h5J6tH" target="_blank" rel="noopener sponsored" class="inline-block bg-red-600 hover:bg-red-700 text-white font-bold text-sm md:text-base py-3 px-6 md:px-8 rounded-full shadow-md transition-transform transform hover:scale-105">
                    楽天ふるさと納税（10,000円〜）をチェックする ▶︎
                </a>
            </div>

            <h2
                id="toptracer"
                class="scroll-mt-24 text-2xl md:text-3xl font-bold text-slate-800 mt-16 mb-4 border-b-2 border-green-500 pb-2"
            >
                【設備】全打席トップトレーサー・レンジが無料で使い放題！
            </h2>
             <Image
                src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6513.jpg"
                alt="KSP彦根の打席。全打席にモニター完備"
                class="w-full h-auto object-cover rounded-lg my-6"
                loading="lazy"
                width={1200}
                height={800}
                format="webp"
                quality={80}
            />
            <p>
                KSP彦根の心臓部とも言えるのが、全80打席に標準装備された「トップトレーサー・レンジ」！これがなんと、追加料金なしで利用可能なのです。
            </p>
            <p>
                打席に立つだけで、あなたのショットの飛距離、弾道、ボール初速といった詳細なデータが、目の前のモニターにリアルタイムで表示されます。
            </p>

            <h3 class="text-xl md:text-2xl font-semibold text-slate-800 mt-8 mb-3">
                🔰初心者ゴルファーの救世主！私の活用術
            </h3>
             <Image
                src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6517.jpg"
                alt="クラブごとの飛距離をデータで把握"
                class="w-full h-auto object-cover rounded-lg my-6"
                loading="lazy"
                width={1200}
                height={800}
                format="webp"
                quality={80}
            />
            <p>
                私自身、初心者なので各番手ごとの正確な飛距離や弾道の傾向をまだ完全に把握できていません。そんな私にとって、このトップトレーサーはまさに「救世主」！
            </p>
            <p>
                特に活用しているのが、「クラブ別測定」モード。番手ごとの飛距離を確認すると、1球ごとの詳細データはもちろん、そのクラブでの平均飛距離や左右のブレ幅などが一目瞭然！「あ、今のショットはトップ気味だったから飛距離が落ちたな」というのを、感覚だけでなくデータで客観的に理解できるのです。
            </p>

             <Image
                src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6527.jpg"
                alt="トップトレーサーのモニター画面＿総飛距離やボール速度などの詳細"
                class="w-full h-auto object-cover rounded-lg my-6"
                loading="lazy"
                width={1200}
                height={800}
                format="webp"
                quality={80}
            />
            <p>
                スマホアプリと連携すれば、練習データを記録して後から見返すことも可能。トップトレーサーは”感覚頼り”の練習から卒業させてくれる”最強の相棒”です。
            </p>

            <h2
                id="ic-card"
                class="scroll-mt-24 text-2xl md:text-3xl font-bold text-slate-800 mt-12 mb-4 border-b-2 border-green-500 pb-2"
            >
                【システム】紛失しても安心便利なICカード！
            </h2>
             <Image
