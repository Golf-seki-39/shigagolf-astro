            <script>
                function initKSPSimulator() {
                    const sim = document.getElementById('ksp-simulator');
                    if(!sim) return;

                    const update = () => {
                        // 【修正】エラーにならないよう、正しく要素を取得
                        const day = document.querySelector('input[name="ksp-day"]:checked')?.value || 'weekday';
                        const floor = document.querySelector('input[name="ksp-floor"]:checked')?.value || '1f';
                        const time = document.getElementById('ksp-time')?.value || 'normal';
                        const user = document.getElementById('ksp-user')?.value || 'general';
                        const rate = parseFloat(document.getElementById('ksp-charge')?.value) || 1.0;
                        const balls = parseInt(document.getElementById('ksp-balls')?.value) || 150;
                        
                        const ballsDisplay = document.getElementById('ksp-balls-val');
                        const totalYen = document.getElementById('ksp-total-yen');
                        const totalPt = document.getElementById('ksp-total-pt');
                        const recBox = document.getElementById('ksp-recommend');
                        const recList = document.getElementById('ksp-recommend-list');

                        if (ballsDisplay) ballsDisplay.textContent = balls + "球";

                        // 打席料
                        let entryFee = 0;
                        if(time !== 'late') {
                            entryFee = (day === 'weekday') ? 220 : 275;
                        }

                        // ボール単価 (pt)
                        let ballPt = 0;
                        if(user === 'women_jr') {
                            ballPt = (day === 'weekday') ? 6.6 : 7.7;
                        } else {
                            if(day === 'weekday') {
                                if(floor === '1f') ballPt = (time === 'early') ? 7.7 : 8.8;
                                else ballPt = (time === 'early') ? 6.6 : 7.7;
                            } else {
                                if(floor === '1f') ballPt = (time === 'early') ? 8.8 : ((time === 'late') ? 8.8 : 9.9);
                                else ballPt = (time === 'early') ? 7.7 : ((time === 'late') ? 7.7 : 8.8);
                            }
                        }

                        // 単価打ち計算
                        let usedPoints = entryFee + (ballPt * balls);
                        
                        // 【特典】一般ユーザーは単価打ちで1球1pt還元（実質値引き）
                        if(user === 'general') {
                            usedPoints -= balls; // 1球1円還元
                        }

                        // チャージ還元率を掛けて実質的な日本円に
                        const realYen = Math.ceil(usedPoints * rate);
                        
                        if (totalPt) totalPt.textContent = Math.ceil(usedPoints).toLocaleString();
                        if (totalYen) totalYen.textContent = realYen.toLocaleString();

                        // 打ち放題(時間打ち)との比較
                        if (recBox) recBox.classList.add('hidden');
                        if(time !== 'late') {
                            let timePrices = {};
                            if(day === 'weekday') {
                                timePrices = (floor === '1f') ? {30: 770, 60: 1320, 90: 1760} : {30: 660, 60: 1210, 90: 1540};
                            } else {
                                timePrices = (floor === '1f') ? {30: 880, 60: 1430, 90: 1980} : {30: 770, 60: 1320, 90: 1870};
                            }

                            let recs = [];
                            Object.entries(timePrices).forEach(([mins, pricePt]) => {
                                const timeRealYen = Math.ceil((pricePt + entryFee) * rate);
                                if(realYen > timeRealYen) {
                                    recs.push(`時間打ち ${mins}分: ¥${timeRealYen.toLocaleString()} <span class="text-xs font-normal text-slate-500">(打席料込)</span>`);
                                }
                            });

                            if(recs.length > 0 && recBox && recList) {
                                recList.innerHTML = recs.join('<br>');
                                recBox.classList.remove('hidden');
                            }
                        }
                    };

                    // イベントリスナーの登録
                    sim.querySelectorAll('input, select').forEach(el => {
                        el.addEventListener('change', update);
                        if(el.type === 'range') el.addEventListener('input', update);
                    });
                    
                    // 初回の計算を実行
                    update();
                }

                // ページ読み込み時に実行
                document.addEventListener('DOMContentLoaded', initKSPSimulator);
                // ※AstroのViewTransitionsを入れた場合も動くようにする保険
                document.addEventListener('astro:page-load', initKSPSimulator);
            </script>
