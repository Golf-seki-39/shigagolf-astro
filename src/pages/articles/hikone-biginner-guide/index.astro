                    <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/%E9%A9%9A%E3%81%8D%E3%81%AE%E5%A5%B3%E6%80%A7%20(2).png" alt="KSP彦根の広大な駐車場" class="rounded-lg shadow-md w-full h-auto object-cover aspect-video" width={400} height={225} format="webp" loading="lazy" />
