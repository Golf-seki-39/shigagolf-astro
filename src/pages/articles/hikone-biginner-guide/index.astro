                </div>
                <div class="w-full md:w-1/2">
                    <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/ksp_hikone/gallery/IMG_6512.png" alt="KSP彦根の打席決済システム" class="rounded-lg shadow-md w-full h-auto object-cover aspect-video" width={400} height={225} format="webp" loading="lazy" />
