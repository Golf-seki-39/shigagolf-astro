                        <thead class="bg-slate-100 border-b-2 border-slate-300">
                            <tr>
                                <th class="py-3 px-4 font-bold text-slate-800">施設名</th>
                                <th class="py-3 px-4 font-bold text-slate-800 text-center">安心度<br><span class="text-xs font-normal">(プレッシャー無)</span></th>
                                <th class="py-3 px-4 font-bold text-slate-800 text-center">女性1人<br><span class="text-xs font-normal">(行きやすさ)</span></th>
                                <th class="py-3 px-4 font-bold text-slate-800 text-center">没入度<br><span class="text-xs font-normal">(干渉されなさ)</span></th>
                                <th class="py-3 px-4 font-bold text-slate-800 text-center">空きやすさ<br><span class="text-xs font-normal">(ゆとり)</span></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-green-700">365彦根</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★★</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★★</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★☆☆</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★★</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-green-700">KSP彦根</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★☆☆</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★☆</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★★</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★☆☆☆</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-green-700">多賀ゴルフ</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★★</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★☆☆</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★★☆</td>
                                <td class="py-4 px-4 text-amber-500 text-center text-lg">★★★☆☆</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <p class="text-sm font-bold text-slate-800 mb-2">▼ レンタル・料金・駐車場の基本スペック比較</p>
            <div class="my-6">
                <div class="md:hidden flex justify-end items-center text-xs font-bold text-green-600 mb-2 animate-pulse">
                 
                </div>
                <div class="not-prose overflow-x-auto border border-slate-300 rounded-lg shadow-sm bg-white mb-8">
                    <table class="w-full text-sm text-left border-collapse min-w-[800px] responsive-table">
                        <thead class="bg-slate-100 border-b-2 border-slate-300">
                            <tr>
                                <th class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">施設名</th>
                                <th class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">レンタルクラブ<br>＆ スタッフ対応</th>
                                <th class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">駐車場</th>
                                <th class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">料金の目安<br>(単価 / 入場料)</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-green-700" data-label="施設名"><a href="#365" class="hover:underline">365彦根</a></td>
                                <td class="py-4 px-4 text-slate-600" data-label="レンタル＆スタッフ">1本 100円<br><span class="text-xs text-blue-600 font-bold">明るく親切な接客</span></td>
