---
// --- [1] AstroとBaseLayoutの設定 ---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

// --- [2] 共通コンポーネントをインポート ---
import AuthorProfile from '../../../components/AuthorProfile.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import MySlider from '../../../components/MySlider.astro';
import Sidebar from '../../../components/Sidebar.astro'; 

// --- [3] この記事固有の情報 ---
const title = "【2026年版】近江八幡・東近江の打ちっぱなしおすすめ完全ガイド｜目的別に選ぶゴルフ練習場 | シガゴル";
const description = "近江八幡市・東近江市周辺のゴルフ練習場をシガゴルが徹底調査！「一番安いのは？」「芝からアプローチしたい」「パターを極めたい」など、あなたの目的に合わせて最適な練習場を案内します。";
const pubDate = "2026-06-23"; // ※公開日に合わせて調整してください
const lastModified = new Date();
const updatedDate = "2026-06-23";


// アイキャッチ画像（旧総合比較の画像を引き継ぎ）
const ogImageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/omi-higasi-hub.jpg";

const baseUrl = "https://shigagolf.com";
// ※フォルダ名（URL）に合わせて変更してください（例: omi-higashiomi-hub にリネーム推奨）
const articleUrl = `${baseUrl}/articles/omi-higashiomi-comparison/`; 
const headline = "【2026年版】近江八幡・東近江の打ちっぱなしおすすめ完全ガイド｜目的別に選ぶゴルフ練習場";

// --- Firebaseから各練習場の情報を取得（構造化データ＆詳細情報用） ---
const rangeIds = [
    "sakura_gc",
    "riverside_jumbo",
    "greenpia_oh",
    "azuchi_gc",
    "garage_park",
    "elgrace_oh" // ELGRACE近江八幡のID（間違っていれば修正してください）
];
const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const rangePromises = rangeIds.map((id) =>
    getDoc(doc(db, `artifacts/${appId}/public/data/practice_ranges/${id}`))
);
const rangeDocs = await Promise.all(rangePromises);

const rangesData = rangeDocs.reduce((acc, docSnap, index) => {
    if (docSnap.exists()) {
        acc[rangeIds[index]] = docSnap.data();
    } else {
        acc[rangeIds[index]] = null;
    }
    return acc;
}, {});

if (rangesData.greenpia_oh) {
    rangesData.greenpia_oh.name = "グリーンピア近江八幡ゴルフ";
}

// --- [4] 目的別の第2階層（中まとめ記事）へのリンク設定 ---
const navPanels = [
    {
        title: "とにかく安く打ちたい！",
        desc: "近江八幡・東近江エリアの最安値はここ。料金・コスパ徹底比較！",
        link: "/articles/comparison/omi-pricerank/",
        icon: "fa-calculator",
        color: "bg-blue-600",
        btnLabel: "料金比較を見る"
    },
    {
        title: "芝からアプローチしたい！",
        desc: "コースデビューの鍵。天然芝やバンカー練習ができる施設を厳選。",
        link: "/articles/omi-higashiomi-approach/", // ※アプローチ特化記事のURL
        icon: "fa-flag",
        color: "bg-emerald-600",
        btnLabel: "ショートゲーム比較を見る"
    },
    {
        title: "パターを徹底的に極めたい！",
        desc: "スコアメイクの要。パター練習場が充実している施設まとめ。",
        link: "/articles/comparison/omi-putting/",
        icon: "fa-golf-ball-tee", 
        color: "bg-indigo-600",
        btnLabel: "パター練習場まとめを見る"
    },
    {
        title: "初心者向け・レッスンを受けたい！",
        desc: "一からゴルフを始めたい方に。初心者向けの環境とレッスン比較。",
        link: "/articles/comparison/omi-lesson/",
        icon: "fa-chalkboard-user",
        color: "bg-rose-600",
        btnLabel: "レッスン・初心者ガイドを見る"
    }
];

// --- [5] スライダー用の関連記事リスト ---
const experienceReports = [
    { url: '/articles/azuchi-review/', title: '安土ゴルフクラブ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/0000image0000.png' },
    { url: '/articles/sakura-gc-review/', title: 'さくらゴルフ倶楽部 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/00000ai.png' },
    { url: '/articles/garege-park-review/', title: 'がれーじぱーく東近江 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/00000ai.jpg' },
    { url: '/articles/review/greenpia-oh/', title: 'グリーンピア近江八幡ゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/シガゴル (14).jpg' },
    { url: '/articles/review/riverside-jumbo/', title: 'リバーサイドジャンボゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/シガゴル (15).jpg' },
];

const comparisonArticles = [
    { url: '/articles/comparison/omi-pricerank/', title: '【料金で徹底比較】近江八幡・東近江の安い練習場5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (2).jpg' },
    { url: '/articles/omi-higashiomi-approach/', title: '【アプローチ＆バンカー練習場】近江八幡・東近江5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/approach.jpg' },
    { url: '/articles/comparison/omi-putting/', title: '【パター練習場が充実】近江八幡・東近江エリア5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル.jpg' },
    { url: '/articles/comparison/omi-lesson/', title: '【レッスン比較】近江八幡・東近江の初心者向け4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (12).jpg' },
];
---

<BaseLayout title={title} description={description} pubDate={pubDate} ogImage={ogImageUrl}>
    
     <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col lg:flex-row gap-8 items-stretch my-8">

        {/* ▼ 左側のメイン記事エリア ▼ */}
        <main id="article-view" class="w-full lg:flex-1 bg-white p-6 md:p-8 rounded-lg shadow-lg text-slate-700 leading-relaxed overflow-hidden">

            {/* ハブ記事自体のパンくず/戻るボタンは「一覧」へ */}
            <a href="/articles/" class="nav-link back-button mb-6 inline-block text-green-700 font-semibold hover:underline">
                ‹ お役立ち記事一覧に戻る
            </a>
            
            <header class="text-center">
                <h1 class="text-3xl md:text-5xl font-black text-slate-800 leading-tight mb-4">{headline}</h1>
                <p class="text-slate-500 mb-8">「あなたにぴったりの練習場」がここなら見つかる</p>
                
                <figure class="m-0 mb-10 overflow-hidden rounded-2xl shadow-xl">
                    <Image 
                        src={ogImageUrl} 
                        alt="近江八幡・東近江エリアのゴルフ練習場ガイド" 
                        class="w-full h-auto object-cover" 
                        inferSize={true}
                    />
                </figure>
            </header>

            {/* --- 案内所（ハブ）としての目的別ナビパネル --- */}
            <section class="not-prose my-12">
                <h2 class="text-2xl font-bold text-slate-800 text-center mb-8 flex justify-center items-center gap-2">
                    <span class="text-3xl">🧭</span> あなたの「目的」はどれですか？
                </h2>
                
                <div class="grid md:grid-cols-2 gap-6">
                    {navPanels.map((panel) => (
                        <a href={panel.link} class="group block bg-white border-2 border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:border-slate-200 transition-all duration-300 no-underline">
                            <div class="flex items-start gap-4">
                                <div class={`${panel.color} text-white p-4 rounded-xl shadow-lg group-hover:scale-110 transition-transform`}>
                                    <i class={`fa-solid ${panel.icon} text-2xl w-8 text-center`}></i>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold text-slate-800 m-0 group-hover:text-blue-700 transition-colors">{panel.title}</h3>
                                    <p class="text-slate-500 text-sm mt-2 mb-4 leading-snug">{panel.desc}</p>
                                    <span class={`inline-block text-xs font-bold py-1 px-3 rounded-full border border-slate-200 text-slate-600 group-hover:bg-slate-800 group-hover:text-white transition-colors`}>
                                        {panel.btnLabel} ＞
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            {/* --- 近江八幡・東近江エリア主要施設一覧（簡易表） --- */}
            <section class="my-16 not-prose">
                <h2 class="text-2xl font-bold text-slate-800 mt-0 mb-6 border-b-2 border-slate-200 pb-2">近江八幡・東近江エリア 主要施設一覧</h2>

                <div class="md:hidden flex justify-end items-center text-xs font-bold text-green-600 mb-2 animate-pulse">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                    表は横にスクロールできます
                </div>

                <div class="overflow-x-auto border border-slate-300 rounded-lg shadow-sm bg-white">
                    <table class="w-full text-sm text-left border-collapse min-w-[500px]">
                        <thead class="bg-slate-100 border-b-2 border-slate-300">
                            <tr>
                                <th class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">施設名</th>
                                <th class="py-3 px-4 font-bold text-slate-800">最大の特徴</th>
                                <th class="py-3 px-4 font-bold text-slate-800 whitespace-nowrap">エリア</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200">
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-green-700">リバーサイドジャンボゴルフ</td>
                                <td class="py-4 px-4 text-slate-700">最高の芝管理。本気でスコアアップを目指す中〜上級者向け。</td>
                                <td class="py-4 px-4 text-slate-500 whitespace-nowrap">東近江市</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-rose-600">さくらゴルフ倶楽部</td>
                                <td class="py-4 px-4 text-slate-700">女性はアプローチ無料！コスパ最強で初心者専用打席も完備。</td>
                                <td class="py-4 px-4 text-slate-500 whitespace-nowrap">東近江市</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-blue-700">グリーンピア近江八幡ゴルフ</td>
                                <td class="py-4 px-4 text-slate-700">特定割引で1球3円！車での道中は少し狭いので要注意。</td>
                                <td class="py-4 px-4 text-slate-500 whitespace-nowrap">近江八幡市</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-amber-700">安土ゴルフクラブ</td>
                                <td class="py-4 px-4 text-slate-700">プリカ不要で手軽。打席利用者はバンカー練習が追加料金なし。</td>
                                <td class="py-4 px-4 text-slate-500 whitespace-nowrap">近江八幡市</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-indigo-700">がれーじぱーく東近江</td>
                                <td class="py-4 px-4 text-slate-700">高性能な弾道測定器を完備。天候に左右されないインドア環境。</td>
                                <td class="py-4 px-4 text-slate-500 whitespace-nowrap">東近江市</td>
                            </tr>
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="py-4 px-4 font-bold text-slate-800">ELGRACE近江八幡</td>
                                <td class="py-4 px-4 text-slate-700">近江八幡エリアのインドア施設。ラグジュアリーで完全個室。</td>
                                <td class="py-4 px-4 text-slate-500 whitespace-nowrap">近江八幡市</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <div class="bg-slate-50 p-6 md:p-8 rounded-2xl border border-slate-200 my-12">
                <h2 class="text-xl font-bold text-slate-800 mt-0 mb-4">目的に合わせて選べば、上達スピードが変わる</h2>
                <p class="text-sm md:text-base m-0">
                    近江八幡・東近江エリアには、上記のように個性豊かな練習場が集まっています。
                    「とにかく安くたくさん打ちたい」「コース前に芝からアプローチを練習したい」「最新のデータを取りたい」など、あなたの今の課題に合わせて練習場を選ぶことが、スコアアップへの一番の近道です。<br><br>
                    シガゴルでは、エリア内の主要施設をすべて実際に訪問し、忖度なしのデータとレビューを作成しました。上記の目的別パネルから、一番必要な情報をチェックしてください。
                </p>
            </div>

            {/* --- 施設詳細と体験談のダブルリンクUI --- */}
            <h2 class="text-2xl font-bold text-slate-800 mt-16 mb-6 border-b-2 border-slate-200 pb-2">調査対象施設の詳細データ・体験レビュー</h2>
            <p>シガゴルでは、各施設の「基本情報（料金や営業時間など）」をまとめたデータベースと、管理人が実際に打ってみた「体験レポート」を分けてご用意しています。気になる施設をチェックしてみてください。</p>
            
            <div class="space-y-6 not-prose mb-12">
                
                {/* リバーサイドジャンボ */}
                <div class="bg-white border border-slate-200 p-5 rounded-xl shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 m-0">リバーサイドジャンボゴルフ</h3>
                        <p class="text-sm text-slate-500 m-0 mt-1">極上の芝管理 / 中〜上級者向け</p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-2">
                        <a href="/ranges/riverside_jumbo/" class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-bold rounded-lg border border-slate-300 hover:bg-slate-200 transition text-center">
                            <i class="fa-solid fa-list-ul mr-1"></i> 施設詳細を見る
                        </a>
                        <a href="/articles/review/riverside-jumbo/" class="px-4 py-2 bg-green-600 text-white text-sm font-bold rounded-lg hover:bg-green-700 transition text-center shadow-sm">
                            <i class="fa-solid fa-pen-nib mr-1"></i> 体験レビューを読む
                        </a>
                    </div>
                </div>

                {/* さくらゴルフ */}
                <div class="bg-white border border-slate-200 p-5 rounded-xl shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 m-0">さくらゴルフ倶楽部</h3>
                        <p class="text-sm text-slate-500 m-0 mt-1">女性特権多数 / 初心者専用打席</p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-2">
                        <a href="/ranges/sakura_gc/" class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-bold rounded-lg border border-slate-300 hover:bg-slate-200 transition text-center">
                            <i class="fa-solid fa-list-ul mr-1"></i> 施設詳細を見る
                        </a>
                        <a href="/articles/sakura-gc-review/" class="px-4 py-2 bg-rose-500 text-white text-sm font-bold rounded-lg hover:bg-rose-600 transition text-center shadow-sm">
                            <i class="fa-solid fa-pen-nib mr-1"></i> 体験レビューを読む
                        </a>
                    </div>
                </div>

                {/* グリーンピア */}
                <div class="bg-white border border-slate-200 p-5 rounded-xl shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 m-0">グリーンピア近江八幡ゴルフ</h3>
                        <p class="text-sm text-slate-500 m-0 mt-1">衝撃の低価格 / 昔ながらの施設</p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-2">
                        <a href="/ranges/greenpia_oh/" class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-bold rounded-lg border border-slate-300 hover:bg-slate-200 transition text-center">
                            <i class="fa-solid fa-list-ul mr-1"></i> 施設詳細を見る
                        </a>
                        <a href="/articles/review/greenpia-oh/" class="px-4 py-2 bg-blue-600 text-white text-sm font-bold rounded-lg hover:bg-blue-700 transition text-center shadow-sm">
                            <i class="fa-solid fa-pen-nib mr-1"></i> 体験レビューを読む
                        </a>
                    </div>
                </div>

                {/* 安土 */}
                <div class="bg-white border border-slate-200 p-5 rounded-xl shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 m-0">安土ゴルフクラブ</h3>
                        <p class="text-sm text-slate-500 m-0 mt-1">現金で手軽 / レッスンがすごい</p>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-2">
                        <a href="/ranges/azuchi_gc/" class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-bold rounded-lg border border-slate-300 hover:bg-slate-200 transition text-center">
                            <i class="fa-solid fa-list-ul mr-1"></i> 施設詳細を見る
                        </a>
                        <a href="/articles/azuchi-review/" class="px-4 py-2 bg-amber-600 text-white text-sm font-bold rounded-lg hover:bg-amber-700 transition text-center shadow-sm">
                            <i class="fa-solid fa-pen-nib mr-1"></i> 体験レビューを読む
                        </a>
                    </div>
                </div>

                {/* がれーじぱーく */}
