---
// src/pages/articles/areas/index.astro
// --- [1] AstroとBaseLayoutの設定 ---
import BaseLayout from "../../../layouts/BaseLayout.astro";

// --- [2] この記事固有の情報 ---
const title = "滋賀県のゴルフ練習場 エリア別ガイド｜シガゴル";
const description = "滋賀県内のゴルフ練習場（打ちっぱなし）をエリア別に徹底ガイド。彦根・多賀、東近江、近江八幡など、お住まいの地域や職場の近くからお気に入りの練習場を見つけてください。";

// ★ 各エリアまとめ記事へのリンク設定
// URLは制作中の記事に合わせて適宜変更してください
const areas = [
    {
        name: "彦根・多賀エリア",
        description: "天然芝アプローチや最新測定器など、個性豊かな施設が揃う激戦区。",
        link: "/articles/hikone-hub/",
        icon: "fa-map-pin",
        color: "text-blue-600",
        bg: "bg-blue-50",
        border: "border-blue-200"
    },
    {
        name: "東近江エリア",
        description: "広々としたフェアウェイと通いやすい料金設定の施設が魅力のエリア。",
        link: "/articles/higashiomi-hub/", // ※制作中のURLに合わせてください
        icon: "fa-location-dot",
        color: "text-green-600",
        bg: "bg-green-50",
        border: "border-green-200"
    },
    {
        name: "近江八幡エリア",
        description: "初心者から上級者まで満足できる、設備充実の定番練習場をピックアップ。",
        link: "/articles/omihachiman-hub/", // ※制作中のURLに合わせてください
        icon: "fa-map",
        color: "text-amber-600",
        bg: "bg-amber-50",
        border: "border-amber-200"
    }
];
---

<BaseLayout title={title} description={description}>
    
    <div class="bg-slate-50 py-12 px-4 min-h-[60vh]">
        <div class="max-w-4xl mx-auto">
            
            <header class="text-center mb-12">
                <div class="inline-block bg-white border border-slate-200 text-slate-600 font-bold px-4 py-1 rounded-full text-sm mb-4 shadow-sm">
                    エリアから探す
                </div>
                <h1 class="text-3xl md:text-4xl font-black text-slate-800 leading-tight mb-4">
                    滋賀県のゴルフ練習場<br class="md:hidden">エリア別ガイド
                </h1>
                <p class="text-slate-500">
                    お探しの地域を選択してください。各エリアの料金比較やおすすめ施設をご案内します。
                </p>
            </header>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {areas.map((area) => (
                    <a href={area.link} class={`group block bg-white border-2 ${area.border} rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 no-underline relative overflow-hidden flex flex-col h-full`}>
                        
                        {/* 背景の装飾アイコン */}
                        <i class={`fa-solid ${area.icon} absolute -right-6 -bottom-6 text-8xl ${area.color} opacity-5 group-hover:scale-110 transition-transform duration-500`}></i>
                        
                        <div class="relative z-10 flex-grow">
                            <div class={`${area.bg} ${area.color} w-14 h-14 rounded-xl flex items-center justify-center text-2xl mb-4 shadow-sm`}>
                                <i class={`fa-solid ${area.icon}`}></i>
                            </div>
                            <h2 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-green-700 transition-colors">
                                {area.name}
                            </h2>
                            <p class="text-slate-600 text-sm leading-relaxed m-0">
                                {area.description}
                            </p>
                        </div>
                        
                        <div class="relative z-10 mt-6 text-right">
                            <span class={`inline-block text-sm font-bold py-2 px-4 rounded-lg bg-slate-100 text-slate-600 group-hover:${area.bg} group-hover:${area.color} transition-colors`}>
                                エリアガイドを見る ＞
                            </span>
                        </div>
                    </a>
                ))}
            </div>

            <div class="mt-12 text-center text-slate-500 text-sm">
                <p>※その他のエリア（大津・草津など）も順次追加予定です。</p>
            </div>

        </div>
    </div>

</BaseLayout>