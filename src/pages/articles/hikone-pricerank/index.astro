    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const simulator = document.getElementById('area-price-simulator');
        if (!simulator) return;

        const userTypeSel = document.getElementById('sim-user-type');
        const dayRadios = document.getElementsByName('sim-day');
        const timeSel = document.getElementById('sim-time-slot');
        const floorRadios = document.getElementsByName('sim-floor');
        const ballSlider = document.getElementById('sim-ball-slider');
        const ballDisplay = document.getElementById('sim-ball-display');
        const resultsContainer = document.getElementById('sim-results');
        const quickBtns = document.querySelectorAll('.sim-quick-btn');

        // 各時間の目安最大球数（この球数以下ならその時間貸しプランが選べる）
        // 30分=80球, 60分=150球, 90分=250球, 120分=350球, 無制限=999球
        function getCheapestPlan(unitTotal, timePlans, reqBalls) {
            let best = { price: unitTotal, isTimePlan: false, name: '' };
            for (let plan of timePlans) {
                if (reqBalls <= plan.maxBalls && plan.price < best.price) {
                    best = { price: plan.price, isTimePlan: true, name: plan.name };
                }
            }
            return best;
        }

        function calculateAll() {
            const userType = userTypeSel.value; // member_m, member_f, visitor_m, visitor_f, junior
            const isMember = userType.startsWith('member');
            const isFemale = userType.endsWith('_f');
            const isJr = userType === 'junior';
            
            const day = document.querySelector('input[name="sim-day"]:checked').value; 
            const time = timeSel.value; 
            const floor = document.querySelector('input[name="sim-floor"]:checked').value; 
            const balls = parseInt(ballSlider.value);

            ballDisplay.textContent = `${balls}球`;

            let results = [];

            // ==========================================
            // 1. 多賀ゴルフの計算
            // ==========================================
            let tagaEntry = 220;
            if (time === 't6_8' || time === 't8_10' || time === 't20_21' || time === 't21_22' || time === 't22_24') {
                tagaEntry = 0; 
            }

            let tagaBallPrice = isMember ? 7.7 : 9.9;
            if (isJr) tagaBallPrice = 4.4;

            if (day === 'weekday' && floor === '2F' && (time === 't6_8' || time === 't8_10')) tagaBallPrice = 6.6; 
            if (time === 't20_21' || time === 't21_22' || time === 't22_24') {
                if(!isJr) tagaBallPrice = 7.7; 
            }
            if (day === 'weekend' && floor === '1F' && time === 't10_20') tagaBallPrice += 1.0; 

            let tagaUnitTotal = tagaEntry + Math.floor(tagaBallPrice * balls);

            // 多賀の打ち放題（時間貸し）プランの構築
            let tagaTimeMod = 0;
            if (day === 'weekday' && floor === '2F') tagaTimeMod -= 100;
            if (day === 'weekend' && floor === '1F') tagaTimeMod += 100;
            if (!isMember && !isJr) tagaTimeMod += 100; // ビジターは+100円

            let tagaPlans = [
                { maxBalls: 80, price: 880 + tagaTimeMod, name: '30分貸し' },
                { maxBalls: 150, price: 1320 + tagaTimeMod, name: '60分貸し' },
                { maxBalls: 250, price: 1870 + tagaTimeMod, name: '90分貸し' }
            ];

            // 平日のメンバー向け無制限（最大500球）
            if (isMember && day === 'weekday' && (time === 't8_10' || time === 't10_20')) {
                tagaPlans.push({ maxBalls: 500, price: isFemale ? 1430 : 1980, name: '平日打ち放題' });
            }

            let tagaBest = getCheapestPlan(tagaUnitTotal, tagaPlans, balls);
            let tagaFinalPrice = tagaBest.price;
            
            let tagaNote = "";
            if (tagaBest.isTimePlan) tagaNote += `<span class="text-pink-400 font-bold text-[10px] md:text-xs">※${tagaBest.name}適用</span><br>`;
            if (isFemale && isMember && day === 'weekday' && (time === 't8_10' || time === 't10_20')) {
                tagaNote += `<span class="text-pink-300 text-[10px] md:text-xs">★月水ならレディースデーで500円！</span>`;
            }

            results.push({ name: '多賀ゴルフ', price: tagaFinalPrice, feature: '登録無料・夜間入場無料', note: tagaNote, color: 'bg-green-600' });


            // ==========================================
            // 2. KSP彦根の計算
            // ==========================================
            let kspEntry = day === 'weekday' ? 220 : 275;
            if (time === 't22_24') kspEntry = 0; 
            let kspOpen = true;
            if (day === 'weekday' && time === 't6_8') kspOpen = false; 

            let kspBallPrice = 0;
            if (day === 'weekday') {
                if (time === 't8_10') kspBallPrice = floor === '1F' ? 7.7 : 6.6;
                else kspBallPrice = floor === '1F' ? 8.8 : 7.7;
            } else {
                if (time === 't6_8') kspBallPrice = floor === '1F' ? 8.8 : 7.7;
                else kspBallPrice = floor === '1F' ? 9.9 : 8.8; 
                if (time === 't22_24') kspBallPrice = floor === '1F' ? 8.8 : 7.7;
            }

            if ((isFemale || isJr) && time !== 't22_24') {
                if (day === 'weekday' && (time === 't10_20' || time === 't20_21' || time === 't21_22')) {
                    kspBallPrice = 6.6;
                } else if (day === 'weekend' && time === 't10_20') {
                    kspBallPrice = 7.7;
                }
            }

            let kspUnitTotal = kspEntry + Math.floor(kspBallPrice * balls);

            // KSPの時間貸しプラン
            let kspPlans = [];
            if (day === 'weekday') {
                kspPlans.push({ maxBalls: 80, price: floor === '1F' ? 770 : 660, name: '30分打ち放題' });
                kspPlans.push({ maxBalls: 150, price: floor === '1F' ? 1320 : 1210, name: '60分打ち放題' });
                kspPlans.push({ maxBalls: 250, price: floor === '1F' ? 1760 : 1540, name: '90分打ち放題' });
            } else {
                kspPlans.push({ maxBalls: 80, price: floor === '1F' ? 880 : 770, name: '30分打ち放題' });
                kspPlans.push({ maxBalls: 150, price: floor === '1F' ? 1430 : 1320, name: '60分打ち放題' });
                kspPlans.push({ maxBalls: 250, price: floor === '1F' ? 1980 : 1870, name: '90分打ち放題' });
            }

            let kspBest = getCheapestPlan(kspUnitTotal, kspPlans, balls);
            let kspFinalPrice = kspOpen ? kspBest.price : 99999;
            
            let kspNote = kspOpen ? "" : "営業時間外";
            if (kspOpen) {
                if (kspBest.isTimePlan) kspNote += `<span class="text-pink-400 font-bold text-[10px] md:text-xs">※${kspBest.name}適用</span><br>`;
                kspNote += `<span class="text-blue-300 text-[10px] md:text-xs">ふるさと納税で実質30%引！</span>`;
            }

            results.push({ name: 'KSP彦根', price: kspFinalPrice, feature: 'ふるさと納税で錬金術', note: kspNote, color: 'bg-blue-600' });


            // ==========================================
            // 3. 365彦根の計算
            // ==========================================
            // メンバー利用は年会費が必要なことを注記
            let h365Entry = isMember ? 0 : 250;
            let h365BallPrice = 0;

            if (isMember) {
                h365BallPrice = day === 'weekday' ? (floor === '1F' ? 7 : 6) : (floor === '1F' ? 9 : 8);
                if (time === 't21_22' || time === 't22_24') h365BallPrice -= 1; 
            } else {
                h365BallPrice = day === 'weekday' ? (floor === '1F' ? 10 : 9) : (floor === '1F' ? 11 : 10);
            }

            let h365UnitTotal = h365Entry + Math.floor(h365BallPrice * balls);

            // 365の時間打ちプラン
            let h365Plans = [];
            let h365_base_60 = isMember ? (floor === '1F' ? 900 : 800) : (floor === '1F' ? 1300 : 1200);
            let h365_base_90 = isMember ? (floor === '1F' ? 1200 : 1100) : (floor === '1F' ? 1600 : 1500);
            let h365_base_120 = isMember ? (floor === '1F' ? 1500 : 1400) : (floor === '1F' ? 1900 : 1800);
            
            if (day === 'weekend') {
                h365_base_60 += 100;
                h365_base_90 += 100;
                h365_base_120 += 100;
            }

            h365Plans.push({ maxBalls: 150, price: h365_base_60, name: '60分打ち放題' });
            h365Plans.push({ maxBalls: 250, price: h365_base_90, name: '90分打ち放題' });
            h365Plans.push({ maxBalls: 350, price: h365_base_120, name: '120分打ち放題' });

            let h365Best = getCheapestPlan(h365UnitTotal, h365Plans, balls);
            let h365FinalPrice = h365Best.price;
            
            let h365Note = "";
            if (h365Best.isTimePlan) h365Note += `<span class="text-pink-400 font-bold text-[10px] md:text-xs">※${h365Best.name}適用</span><br>`;
            if (isFemale) h365Note += `<span class="text-pink-300 text-[10px] md:text-xs">★女性専用プリカ利用で実質さらに20%OFF！</span>`;

            results.push({ name: '365彦根', price: h365FinalPrice, feature: 'アプローチ◎・超穴場', note: h365Note, color: 'bg-indigo-600' });


            // ==========================================
            // ランキング表示
            // ==========================================
            results.sort((a, b) => a.price - b.price);

            let html = "";
            results.forEach((r, index) => {
                const rankIcon = index === 0 ? "🥇" : index === 1 ? "🥈" : "🥉";
                const priceStr = r.price === 99999 ? "---" : `¥${r.price.toLocaleString()}`;
                
                html += `
                <div class="flex items-center justify-between p-3 bg-slate-700 rounded-lg border border-slate-600 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-2 ${r.color}"></div>
                    <div class="pl-4">
                        <div class="flex items-center gap-2">
                            <span class="text-xl">${rankIcon}</span>
                            <span class="font-bold text-white text-lg">${r.name}</span>
                        </div>
                        <p class="text-[10px] md:text-xs text-slate-400 mt-0.5">${r.feature}</p>
                        ${r.note ? `<p class="mt-0.5 leading-tight">${r.note}</p>` : ''}
                    </div>
                    <div class="text-right pl-2 shrink-0">
                        <p class="text-[10px] md:text-xs text-slate-400">最安料金</p>
                        <p class="text-xl md:text-2xl font-black text-white">${priceStr}</p>
                    </div>
                </div>`;
            });

            resultsContainer.innerHTML = html;
        }

        // イベントリスナーの登録
        [userTypeSel, timeSel].forEach(el => el.addEventListener('change', calculateAll));
        Array.from(dayRadios).forEach(r => r.addEventListener('change', calculateAll));
        Array.from(floorRadios).forEach(r => r.addEventListener('change', calculateAll));
        ballSlider.addEventListener('input', calculateAll);

        quickBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                ballSlider.value = e.target.dataset.value;
                calculateAll();
            });
        });

        // 初回計算
        calculateAll();
    });
    </script>
</BaseLayout>