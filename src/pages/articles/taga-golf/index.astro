                    <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/taga_gr/gallery/IMG_1510.png" alt="多賀ゴルフ練習場のすぐ隣にある多賀スマートICのETCゲート" class="w-full h-auto object-cover rounded-lg border border-slate-200" width={800} height={600} format="webp" quality={80} />
                </figure>
                <p class="text-sm text-slate-700 m-0">
                    写真の通り、すぐ隣に名神高速道路の「多賀スマートIC」のETCゲートが開通しています。左に大きく曲げてネットを超えるような打球には要注意です！
                </p>
            </div>

            {/* --- 大まとめ（ハブ記事）への誘導バナー --- */}
            <HikoneHubBanner />

            <div class="not-prose my-12 space-y-12">
            {
                category === '体験談' ? (
                    <>
                        <MySlider articles={comparisonArticles} title="あわせて読みたい「比較記事」"/>
                        <MySlider articles={experienceReports} title="あわせて読みたい「体験談」"/>
                    </>
                ) 
                : category === '比較記事' ? (
                    <>
                        <MySlider articles={experienceReports} title="あわせて読みたい「体験談」"/>
                        <MySlider articles={comparisonArticles} title="あわせて読みたい「比較記事」"/>
                    </>
                ) 
                : null
            }
            </div>

            <AuthorProfile />
            <ShareButtons articleUrl={articleUrl} headline={headline} />

            <h2 id="info" class="scroll-mt-24 text-2xl md:text-3xl font-bold text-slate-800 mt-12 mb-4">基本情報まとめ・営業時間・アクセス</h2>
            
            <div class="overflow-x-auto not-prose my-6 border border-slate-200 rounded-lg">
                <table class="w-full text-left border-collapse table-auto responsive-table">
                    <thead>
                        <tr class="bg-slate-100 border-b border-slate-200">
                            <th class="py-3 px-4 font-semibold text-slate-800">項目</th>
                            <th class="py-3 px-4 font-semibold text-slate-800">情報</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">練習場名</td>
                            <td class="py-3 px-4 text-slate-900" data-label="情報">{rangeData.name}</td>
                        </tr>
                        {rangeData.avgRating && (
                            <tr class="border-b border-slate-200 bg-white">
                                <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">総合評価</td>
                                <td class="py-3 px-4" data-label="情報">
                                    <div class="flex items-center" role="img" aria-label={`評価 ${parseFloat(rangeData.avgRating).toFixed(1)}/5`}>
                                        <span class="font-bold text-amber-500 mr-2 text-lg">{parseFloat(rangeData.avgRating).toFixed(1)}</span>
                                        {Array.from({ length: 5 }).map((_, i) => (
                                            <svg class={`w-5 h-5 ${i < Math.round(parseFloat(rangeData.avgRating)) ? 'text-amber-400' : 'text-slate-300'}`} fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8-2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                            </svg>
                                        ))}
                                    </div>
                                </td>
                            </tr>
                        )}
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">住所</td>
                            <td class="py-3 px-4" data-label="情報">
                                <a href={mapsSearchUrl} target="_blank" rel="noopener noreferrer" class="text-green-700 hover:underline">
                                    {rangeData.address}
                                </a>
                            </td>
                        </tr>
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">電話番号</td>
                            <td class="py-3 px-4" data-label="情報">
                                {rangeData.phone ? (
                                    <a href={`tel:${rangeData.phone.replace(/-/g, "")}`} class="text-green-700 hover:underline">
                                        {rangeData.phone}
                                    </a>
                                ) : (
                                    <span>-</span>
                                )}
                            </td>
                        </tr>
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">営業時間</td>
                            <td class="py-3 px-4 text-slate-900" data-label="情報" set:html={rangeData.business_hours.replace(/\n/g, '<br />')} />
                        </tr>
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">料金（代表例）</td>
                            <td class="py-3 px-4 text-slate-900" data-label="情報">記事上部の料金表をご確認ください</td>
                        </tr>
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">ヤード数</td>
                            <td class="py-3 px-4 text-slate-900" data-label="情報">{rangeData.yardage}ヤード</td>
                        </tr>
                        <tr class="border-b border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">打席数</td>
                            <td class="py-3 px-4 text-slate-900" data-label="情報">{rangeData.bays !== "不明" ? `${rangeData.bays}打席` : "-"}</td>
                        </tr>
                        <tr class="border-slate-200 bg-white">
                            <td class="py-3 px-4 font-medium text-slate-700 bg-slate-50" data-label="項目">アクセス</td>
                            <td class="py-3 px-4 text-slate-900" data-label="情報">{rangeData.access}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <div class="map-container not-prose my-8 rounded-lg overflow-hidden border">
                <iframe
                    src={mapsEmbedUrl}
                    width="100%" height="450" style="border:0;"
                    allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
            </div>
            
        </article>
        </main> {/* ← メイン記事エリアを閉じる */}

        {/* ▼ 右側のサイドバーを呼び出す ▼ */}
        <Sidebar />
    </div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const simulator = document.getElementById('price-simulator');
        if (!simulator) return;

        // --- 多賀ゴルフ練習場 料金データ定義 ---
        const priceData = {
            balls: {
                member: { base: 7.7 },
                visitor: { base: 9.9 }
            },
            time: {
                min30: 880,
                min60: 1320,
                min90: 1870
            },
            unlimited: {
                men: 1980,
                women: 1430,
                ladies_day: 500 // 月水限定 1時間
            }
        };

        // 要素取得
        const planSelect = simulator.querySelector('#plan-select');
        const dayRadios = simulator.querySelectorAll('input[name="day"]');
        const floorRadios = simulator.querySelectorAll('input[name="floor"]');
        const timeRadios = simulator.querySelectorAll('input[name="time"]');
        const ballCountSlider = simulator.querySelector('#ball-count');
        const ballCountDisplay = simulator.querySelector('#ball-count-display');
        const totalPriceDisplay = simulator.querySelector('#total-price');
        const timeOptionsDisplay = simulator.querySelector('#time-options-display');
        const alternativePlans = simulator.querySelector('#alternative-plans');
        const quickBtns = simulator.querySelectorAll('.quick-ball-btn'); 

        function calculatePrice() {
            // ① スライダーの値は必ず表示を更新する（未選択項目があってもスライダーは動く）
            const balls = parseInt(ballCountSlider.value);
            ballCountDisplay.textContent = `${balls}球`;

            const plan = planSelect.value;
            const dayEl = simulator.querySelector('input[name="day"]:checked');
            const floorEl = simulator.querySelector('input[name="floor"]:checked');
            const timeEl = simulator.querySelector('input[name="time"]:checked');

            // ② 必須項目（①〜④）が一つでも未選択なら計算をストップ（----表示のまま）
            if (!plan || !dayEl || !floorEl || !timeEl) {
                totalPriceDisplay.textContent = "----";
                timeOptionsDisplay.classList.add('hidden');
                return;
            }

            // ③ すべて選択されていれば計算を実行
            const day = dayEl.value;
            const floor = floorEl.value;
            const time = timeEl.value;

            // 【単価打ち計算】
            let entryFee = 220;
            if (time === 'early') entryFee = 0; // 早朝は入場料無料

            let ballPrice = priceData.balls[plan].base;
            
            // 夜間(20-23時)はビジターも7.7円
            if (time === 'night') ballPrice = 7.7;
            
            // 平日2階早朝(10時迄)は6.6円
            if (day === 'weekday' && floor === 'floor2' && time === 'early') ballPrice = 6.6;

            // 土日祝の1階(10-20時)は+1円
            if (day === 'weekend' && floor === 'floor1' && time === 'daytime') ballPrice += 1;

            const ballTotal = entryFee + Math.floor(ballPrice * balls);
            totalPriceDisplay.textContent = ballTotal.toLocaleString();

            // 【時間貸し・打ち放題の提案計算】
            let altHTML = "";
            let hasBetterPlan = false;

            // 時間貸し計算
            let timeMod = 0;
            if (day === 'weekday' && floor === 'floor2') timeMod -= 100;
            if (day === 'weekend' && floor === 'floor1') timeMod += 100;
            if (plan === 'visitor') timeMod += 100;

            const price30 = priceData.time.min30 + timeMod;
            const price60 = priceData.time.min60 + timeMod;
            const price90 = priceData.time.min90 + timeMod;

            if (ballTotal >= price30) {
                altHTML += `<li>時間貸し(30分): ¥${price30.toLocaleString()}</li>`;
                hasBetterPlan = true;
            }
            if (ballTotal >= price60) {
                altHTML += `<li>時間貸し(60分): ¥${price60.toLocaleString()}</li>`;
                hasBetterPlan = true;
            }
            if (ballTotal >= price90) {
                altHTML += `<li>時間貸し(90分): ¥${price90.toLocaleString()}</li>`;
                hasBetterPlan = true;
            }

            // 打ち放題計算 (メンバーのみ、平日8:30〜20:00受付)
            if (plan === 'member' && day === 'weekday' && (time === 'early' || time === 'daytime')) {
                if (ballTotal >= priceData.unlimited.men) {
                     altHTML += `<li class="mt-2 text-green-700 font-bold">【平日限定】打ち放題(5時間/500球): 男性¥1,980</li>`;
                     hasBetterPlan = true;
                } else if (ballTotal >= priceData.unlimited.women) {
                     // 男性1980円には届かないが、女性1430円には届いている場合
                     altHTML += `<li class="mt-2 text-green-700 font-bold">【平日限定】打ち放題(5時間/500球): 女性¥1,430 (※男性¥1,980)</li>`;
                     hasBetterPlan = true;
                }
                
                // レディースデー(月水限定想定)
                if (ballTotal >= priceData.unlimited.ladies_day) {
                     altHTML += `<li class="text-pink-600 font-bold">★月・水ならレディースデー！ 1時間 ¥500</li>`;
                     hasBetterPlan = true;
                }
            }

            if (hasBetterPlan) {
                alternativePlans.innerHTML = `<ul class="list-disc list-inside">${altHTML}</ul>`;
                timeOptionsDisplay.classList.remove('hidden');
            } else {
                alternativePlans.innerHTML = "";
                timeOptionsDisplay.classList.add('hidden');
            }
        }

        // イベントリスナー
        planSelect.addEventListener('change', calculatePrice);
        dayRadios.forEach(radio => radio.addEventListener('change', calculatePrice));
        floorRadios.forEach(radio => radio.addEventListener('change', calculatePrice));
        timeRadios.forEach(radio => radio.addEventListener('change', calculatePrice));
        ballCountSlider.addEventListener('input', calculatePrice);
        
        quickBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const target = e.target;
                ballCountSlider.value = target.dataset.value;
                calculatePrice();
            });
        });

        // ページ読み込み時に初回の計算を強制実行（初期状態は空なので計算は走るが金額は更新されない）
        calculatePrice();
    });
    </script>
</BaseLayout>