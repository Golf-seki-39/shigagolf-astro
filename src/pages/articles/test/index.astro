---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

// --- 共通コンポーネント ---
import MySlider from '../../../components/MySlider.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';

// --- この記事固有の情報 ---
const baseUrl = "https://shigagolf.com";
const articleUrl = `${baseUrl}/articles/comparison/omi-priceRank/`;
const publicationDate = "2025-10-03";
const lastModified = new Date();

// --- SEO対策：GSCで強い「打ちっぱなし 滋賀 安い」を最前面に ---
const title = "【滋賀の打ちっぱなし】安い練習場はどこ？料金・コスパで5施設を徹底比較（近江八幡・東近江）";
const description = "滋賀県（近江八幡・東近江）で一番安い打ちっぱなしはどこ？「平日ならグリーンピア」「短時間なら安土」「女性ならさくら」など、総額料金で徹底比較。滋賀の寒い冬でも損しない選び方を管理人が本音でレビュー。";
const headline = "滋賀で一番安い打ちっぱなしはどこ？近江八幡・東近江のゴルフ練習場5施設を料金比較";
const imageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (2).jpg";

// --- Firebaseデータ取得 ---
const rangeIds = ['azuchi_gc', 'greenpia_oh', 'sakura_gc', 'riverside_jumbo', 'garage_park'];
const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const rangePromises = rangeIds.map(id => getDoc(doc(db, `artifacts/${appId}/public/data/practice_ranges/${id}`)));
const rangeDocs = await Promise.all(rangePromises);

const rangesData = rangeDocs.reduce((acc, docSnap, index) => {
    if (docSnap.exists()) { acc[rangeIds[index]] = docSnap.data(); }
    else { acc[rangeIds[index]] = null; }
    return acc;
}, {});

if (rangesData.greenpia_oh) {
    rangesData.greenpia_oh.name = "グリーンピア近江八幡ゴルフ";
}

// --- 各施設の追加情報（レビュー本文・環境・リンク） ---
const additionalData = {
    azuchi_gc: {
        parking: '約40台', access: 'JR安土駅から車で5分', environment: '昔ながらの雰囲気。駐車場も停めやすい。',
        reviewUrl: '/articles/azuchi-review/', rangeUrl: '/ranges/azuchi_gc/',
        reviewText: 'プリペイドカード不要で、現金で気軽に練習できるのが最大の魅力。アットホームな雰囲気で、ゴルフ練習場デビューに最適。駐車場も広く停めやすいです。バンカー練習場も無料で利用できます。',
        altFull: '安土ゴルフクラブの打席全景', altDetail: '安土ゴルフクラブの700円券売機',
    },
    greenpia_oh: {
        parking: '約80台', access: '名神竜王ICから車で10分', environment: '<strong>道中が狭く、運転に注意</strong>',
        reviewUrl: '/articles/review/greenpia-oh/', rangeUrl: '/ranges/greenpia_oh/',
        reviewText: '施設の古さはあるものの、それを補って余りある価格設定が特徴。特に平日日中の料金や、SDカード割引を組み合わせることで、驚異的な安さを実現します。',
        altFull: 'グリーンピア近江八幡の練習スペース', altDetail: '2階打席からの眺め',
    },
    sakura_gc: {
        parking: '約50台', access: '名神竜王ICから車で15分', environment: '冷房が快適。一部駐車しにくい箇所あり',
        reviewUrl: '/articles/sakura-gc-review/', rangeUrl: '/ranges/sakura_gc/',
        reviewText: '女性やジュニアへの特典が非常に手厚く、対象者にとっては最高の練習環境です。夏場は冷房が強く快適。広々としたアプローチ練習場も魅力です。',
        altFull: 'さくらゴルフ倶楽部の打席エリア', altDetail: 'アプローチ練習グリーン',
    },
    riverside_jumbo: {
        parking: '約40台', access: '名神八日市ICから車で10分', environment: 'リニューアルで快適。駐車場も良好。',
        reviewUrl: '/articles/review/riverside-jumbo/', rangeUrl: '/ranges/riverside_jumbo/',
        reviewText: '「安さ」よりも「質」を求めるゴルファーが集う場所。無料で使える本格パターグリーンや質の高いアプローチ場は投資価値あり。2025年6月にリニューアル済。',
        altFull: 'リバーサイドジャンボのフェアウェイ', altDetail: '無料のパターグリーン',
    },
    garage_park: {
        parking: '約20台', access: '蒲生スマートICから車で2分', environment: 'インドアで快適。IC直結でアクセス◎',
        reviewUrl: '/articles/garege-park-review/', rangeUrl: '/ranges/garage_park/',
        reviewText: '蒲生スマートICから2分。天候や寒さを気にせず練習したい方向け。月額5,000円のフリーパスは、練習頻度が高い人にとって最高のコスパです。',
        altFull: 'がれーじぱーくの練習ブース', altDetail: '弾道測定器の画面',
    }
};

// --- 写真URLデータ ---
const images = {
    azuchi_gc: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8076 2.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8069 2.png" },
    greenpia_oh: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/IMG_6879.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/名称未設定.png" },
    sakura_gc: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_9787.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_6020.jpg" },
    riverside_jumbo: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_6450 2.jpg", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_9009.png" },
    garage_park: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/IMG_9502.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/シガゴル.jpg" }
};

// --- JSON-LD構造化データ ---
const mainEntity = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": headline,
    "description": description,
    "image": [imageUrl, images.azuchi_gc.full, images.greenpia_oh.full, images.sakura_gc.full],
    "author": { "@type": "Person", "name": "関（シガゴル運営者）", "url": `${baseUrl}/about/` },
    "publisher": { "@type": "Organization", "name": "シガゴル", "logo": { "@type": "ImageObject", "url": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/logo.png" }},
    "datePublished": new Date(publicationDate).toISOString(), 
    "dateModified": lastModified.toISOString()
};

const faqElements = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "滋賀で一番安い打ちっぱなしは？", "acceptedAnswer": { "@type": "Answer", "text": "100球以内の短時間練習なら入場料無料の安土ゴルフクラブ、平日昼間に200球以上打つなら球単価が安いグリーンピア近江八幡ゴルフが最安クラスです。" } },
    { "@type": "Question", "name": "がれーじぱーく東近江はレッスンやってる？", "acceptedAnswer": { "@type": "Answer", "text": "現在、がれーじぱーく東近江では定期的なゴルフレッスンは開講されていません。当施設はインドアのシミュレーションゴルフ施設です。" } }
  ]
};

// --- 関連記事リスト（ここがエラーの原因でした。しっかり定義します） ---
const experienceReports = [
    { url: '/articles/azuchi-review/', title: '安土ゴルフクラブ 体験レポート', img: images.azuchi_gc.full },
    { url: '/articles/sakura-gc-review/', title: 'さくらゴルフ倶楽部 体験レポート', img: images.sakura_gc.full },
    { url: '/articles/garege-park-review/', title: 'がれーじぱーく東近江 体験レポート', img: images.garage_park.full },
    { url: '/articles/review/greenpia-oh/', title: 'グリーンピア近江八幡ゴルフ 体験レポート', img: images.greenpia_oh.full },
    { url: '/articles/review/riverside-jumbo/', title: 'リバーサイドジャンボゴルフ 体験レポート', img: images.riverside_jumbo.full },
];

const comparisonArticles = [
    { url: '/articles/comparison/omi-lesson/', title: '【レッスン比較】近江八幡・東近江の初心者向け4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (12).jpg' },
    { url: '/articles/omi-higashiomi-approach/', title: '【アプローチ練習場】近江八幡・東近江5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/approach.jpg' },
    { url: '/articles/comparison/omi-putting/', title: '【パター練習場が充実】近江八幡・東近江エリア5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル.jpg' },
];

const gmapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<BaseLayout title={title} description={description} pubDate={publicationDate} ogImage={imageUrl}>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(mainEntity)} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqElements)} />
    
    <div id="article-view" class="view bg-white p-6 md:p-8 rounded-lg shadow-lg max-w-4xl mx-auto text-slate-700">
        <a href="/articles/" class="nav-link back-button mb-6 text-green-700 font-semibold hover:underline">‹ 記事一覧に戻る</a>
        
        <article class="prose lg:prose-xl max-w-none leading-relaxed">
            <style is:global>
              html { scroll-behavior: smooth; }
              section[id] { scroll-margin-top: 80px; }
              .faq-details summary::-webkit-details-marker { display: none; }
              .faq-details summary { list-style: none; outline: none; }
              .btn-shadow { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
              .term-tip { border-bottom: 2px dotted #059669; cursor: help; position: relative; display: inline-block; font-weight: bold; color: #064e3b; }
              .term-tip:hover::after { content: attr(data-tip); position: absolute; bottom: 125%; left: 50%; transform: translateX(-50%); background: #1e293b; color: #fff; padding: 8px 12px; border-radius: 6px; font-size: 0.75rem; width: 220px; line-height: 1.4; z-index: 50; }
              .table-wrapper { overflow-x: auto; }
              .min-w-table-pc { min-width: 650px; }
            </style>
                        
            <header>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-800">{headline}</h1>
                <p class="text-sm text-slate-500 mt-2 text-right">最終更新日：{lastModified.toLocaleDateString('ja-JP')}</p>
            </header>

            <Image src={imageUrl} alt="滋賀の安い打ちっぱなし比較" class="w-full h-auto object-cover rounded-lg my-6" width={1200} height={675} fetchpriority="high" />

            {/* --- 結論ナビ --- */}
            <div class="not-prose bg-green-50 p-6 rounded-lg border-2 border-green-600 shadow-sm my-8">
                <h3 class="text-xl font-bold text-slate-800 mb-4 text-center">💰 【結論】利用シーン別・最安の練習場 💰</h3>
                <ul class="space-y-3">
                    <li class="flex items-start"><span class="text-2xl mr-2">🏃</span><div><span class="font-bold text-slate-800 block text-base">100球以内のサクッと練習なら</span><a href="#azuchi_gc" class="text-blue-600 font-bold underline text-lg">安土ゴルフクラブ</a> <span class="text-xs text-slate-600">(入場料無料)</span></div></li>
                    <li class="flex items-start"><span class="text-2xl mr-2">☀️</span><div><span class="font-bold text-slate-800 block text-base">平日昼間に200球以上打つなら</span><a href="#greenpia_oh" class="text-blue-600 font-bold underline text-lg">グリーンピア近江八幡</a> <span class="text-xs text-slate-600">(SDカード割引あり)</span></div></li>
                    <li class="flex items-start"><span class="text-2xl mr-2">👩</span><div><span class="font-bold text-slate-800 block text-base">女性・ジュニア・快適性重視なら</span><a href="#sakura_gc" class="text-blue-600 font-bold underline text-lg">さくらゴルフ倶楽部</a> <span class="text-xs text-slate-600">(特典が非常に手厚い)</span></div></li>
                </ul>
            </div>

            <p><strong>【告白】私は一度、ゴルフレッスンで心を折られました。</strong></p>
            <p>ゴルフを始めてすぐの頃、「そんなことも知らないのか」と言いたげなプロの態度に、私の心はポッキリと折れました。あの日以来、私はレッスンから距離を置き、遠回りを承知で独学の道を選んできたのです。</p>

            {/* 滋賀の冬サボり防止メッセージ */}
            <div class="not-prose bg-blue-50 p-6 rounded-lg my-8 border-l-4 border-blue-500 text-blue-900">
                <p class="font-bold mt-0 flex items-center">❄️ 滋賀の冬、独学は「サボり」の始まり？</p>
                <p class="mb-0 text-sm md:text-base leading-relaxed">
                    滋賀の冬は寒さが厳しく、一人だとつい練習をサボりがちですよね。だからこそ、<strong>予約制のレッスンを入れて「サボれない環境」を強制的に作る</strong>のも、上達への賢い戦略です。冬の間にプロと土台を作っておけば、春のシーズンには見違えるスイングになっていますよ。
                </p>
            </div>

            <p>この記事は、あなたが<strong>お金と時間を無駄にせず、最高のゴルフライフの第一歩を踏み出すための「防衛マニュアル」</strong>です。初心者には分かりにくい用語解説と、デメリットも本音で書きました。</p>

            <section id="review-details">
                 <h2 class="text-2xl font-bold mt-8 pt-4 border-t border-slate-200">【実体験】滋賀県内5つのゴルフ練習場 本音レビュー</h2>
                 
                 {rangeIds.map(id => {
                     const range = rangesData[id];
                     const extra = additionalData[id];
                     if (!range) return null;
                     return (
                         <div id={id} class="mt-12 pt-6 border-t border-slate-100 scroll-mt-24">
                             <h3 class="text-2xl font-bold text-slate-800 mt-0"><a href={extra.rangeUrl} class="text-green-700 hover:underline">{range.name}</a></h3>
                             
                             <Image src={images[id].full} alt={extra.altFull} class="w-full h-auto object-cover rounded-lg my-4" />
                             
                             <p set:html={extra.reviewText} />
                             
                             <Image src={images[id].detail} alt={extra.altDetail} class="w-full h-auto object-cover rounded-lg my-4" />
                             
                             <div class="bg-red-50 p-4 rounded-lg border-l-4 border-red-500 my-4 text-sm">
                                <p class="font-bold text-red-700 mb-1">⚠️ デメリット・注意点</p>
                                <p class="m-0 text-slate-600 leading-relaxed">
                                    {id === 'azuchi_gc' && "施設は昔ながら。オートティーアップ機はありませんが、その分安く集中できます。"}
                                    {id === 'greenpia_oh' && "練習場へ向かう道中がかなり狭いです。運転に不慣れな方はご注意を。"}
                                    {id === 'sakura_gc' && "人気施設のため、駐車場や打席が混雑しやすい時間帯があります。"}
                                    {id === 'riverside_jumbo' && "入場料・単価ともにエリア標準〜高め。無料のパター練習等をフル活用しましょう。"}
                                    {id === 'garage_park' && "屋外へのアプローチ練習場などはありません。インドアでのデータ分析がメインです。"}
                                </p>
                             </div>
                             
                             <div class="not-prose flex flex-col md:flex-row items-center justify-center gap-4 my-8">
                                <a href={extra.reviewUrl} class="w-full md:w-auto inline-flex items-center justify-center bg-orange-500 text-white font-bold py-3 px-8 rounded-lg no-underline btn-shadow hover:bg-orange-600 transition-all">管理人の詳細体験談を読む</a>
                                <a href={extra.rangeUrl} class="w-full md:w-auto inline-flex items-center justify-center bg-green-700 text-white font-bold py-3 px-8 rounded-lg no-underline btn-shadow hover:bg-green-800 transition-all">練習場の詳細情報を見る</a>
                             </div>
                         </div>
                     )
                 })}
            </section>

            {/* --- ここから詳細比較表 --- */}
            <section id="price-comparison-ball">
                <h2 class="text-2xl font-bold mt-12 pt-4 border-t-2 border-green-600 text-slate-800">【料金】球貸し料金 徹底比較（時間帯別）</h2>
                
                <h3 class="text-xl font-bold mt-6">☀️ 日中（9:00〜17:00）の部</h3>
                <p class="text-sm mb-4">総額がイメージしやすいように<span class="term-tip" data-tip="打席に入るだけでかかる席料のこと。">入場料</span>も併記します。</p>
                <div class="table-wrapper not-prose my-4">
                    <table class="w-full text-sm border border-slate-300 min-w-table-pc text-center">
                        <thead class="bg-slate-100 text-slate-700 font-bold">
                            <tr><th class="px-4 py-3 border text-left">練習場名</th><th class="px-4 py-3 border">平日 (入場料+単価)</th><th class="px-4 py-3 border">土日祝 (入場料+単価)</th></tr>
                        </thead>
                        <tbody>
                            <tr><td class="px-4 py-2 border font-bold text-left text-blue-600">安土ゴルフクラブ</td><td class="px-4 py-2 border">0円 + 7円 ※</td><td class="px-4 py-2 border">0円 + 7円 ※</td></tr>
                            <tr class="bg-slate-50"><td class="px-4 py-2 border font-bold text-left text-blue-600">グリーンピア近江八幡</td><td class="px-4 py-2 border">300円 + 5円</td><td class="px-4 py-2 border">300円 + 7円</td></tr>
                            <tr><td class="px-4 py-2 border font-bold text-left text-blue-600">さくらゴルフ倶楽部</td><td class="px-4 py-2 border">280円 + 7円</td><td class="px-4 py-2 border">320円 + 9円</td></tr>
                        </tbody>
                    </table>
                    <p class="text-xs text-slate-500 mt-2">※安土は1カゴ(100球)700円固定。 ※グリーンピアはSDカード提示でさらに割引あり。</p>
                </div>

                <h3 class="text-xl font-bold mt-8">🌙 夜間（17:00〜）の部</h3>
                <div class="table-wrapper not-prose my-4">
                    <table class="w-full text-sm border border-slate-300 min-w-table-pc text-center">
                        <thead class="bg-slate-100 font-bold">
                            <tr><th class="px-4 py-3 border text-left">練習場名</th><th class="px-4 py-3 border">平日</th><th class="px-4 py-3 border">土日祝</th></tr>
                        </thead>
                        <tbody>
                            <tr class="bg-yellow-50"><td class="px-4 py-2 border font-bold text-left">安土ゴルフクラブ</td><td class="px-4 py-2 border font-bold text-red-600" colspan="2">ナイターサービス：1,200円 / 300球</td></tr>
                            <tr><td class="px-4 py-2 border font-bold text-left">グリーンピア近江八幡</td><td class="px-4 py-2 border">300円 + 5円</td><td class="px-4 py-2 border">300円 + 7円</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="total-cost-simulation">
                <h2 class="text-2xl font-bold mt-12 pt-4 border-t border-slate-200">【検証】100球打った時の総額ランキング</h2>
                <div class="table-wrapper not-prose my-4">
                    <table class="w-full text-sm border border-slate-300 min-w-table-pc text-center">
                        <thead class="bg-green-600 text-white font-bold">
                            <tr><th class="px-4 py-3 border">順位</th><th class="px-4 py-3 border">練習場名</th><th class="px-4 py-3 border">計算内訳</th><th class="px-4 py-3 border">総額</th></tr>
                        </thead>
                        <tbody>
                            <tr><td class="px-4 py-2 border font-bold text-xl text-orange-500 italic">1位</td><td class="px-4 py-2 border font-bold text-left text-blue-600">安土ゴルフクラブ</td><td class="px-4 py-2 border">100球券 (入場無料)</td><td class="px-4 py-2 border font-bold text-lg text-red-600">700円</td></tr>
                            <tr class="bg-slate-50"><td>2位</td><td class="px-4 py-2 border font-bold text-left text-blue-600">グリーンピア近江八幡</td><td>入場300円 + (5円×100)</td><td class="px-4 py-2 border font-bold">800円</td></tr>
                            <tr><td>3位</td><td class="px-4 py-2 border font-bold text-left text-blue-600">さくらゴルフ倶楽部</td><td>入場280円 + (7円×100)</td><td class="px-4 py-2 border font-bold">980円</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="price-comparison-buffet">
                <h2 class="text-2xl font-bold mt-12 pt-4 border-t border-slate-200">【打ち放題】たくさん打つならどこ？</h2>
                <div class="table-wrapper not-prose my-4 text-sm">
                    <table class="w-full border border-slate-300 min-w-table-pc">
                        <thead class="bg-slate-100 font-bold">
                            <tr><th class="px-4 py-3 border text-left">練習場名</th><th class="px-4 py-3 border text-center">主なプラン</th><th class="px-4 py-3 border text-left">ポイント</th></tr>
                        </thead>
                        <tbody>
                            <tr><td class="px-4 py-3 border font-bold">安土ゴルフクラブ</td><td class="px-4 py-3 border text-center">1,200円 / 3時間(2F)</td><td class="px-4 py-3 border">時間制限が長くコスパ最強</td></tr>
                            <tr class="bg-slate-50"><td class="px-4 py-3 border font-bold">がれーじぱーく東近江</td><td class="px-4 py-3 border text-center">月額5,000円 / 無制限</td><td class="px-4 py-3 border text-red-600 font-bold">通う頻度が高いならこれ一択</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            {/* --- FAQ --- */}
            <section id="faq" class="mt-12 pt-6 border-t scroll-mt-24">
                 <h2 class="text-2xl font-bold text-slate-800 mb-6">滋賀の打ちっぱなし選び よくある質問</h2>
                 <div class="space-y-4 not-prose">
                    <details class="faq-details group border rounded-lg bg-slate-50 p-4 overflow-hidden transition-all duration-300">
                        <summary class="font-bold cursor-pointer flex justify-between items-center">Q. がれーじぱーく東近江はレッスンやってる？<span class="text-green-600 transition group-open:rotate-180">▼</span></summary>
                        <p class="mt-4 text-sm text-slate-600 border-t pt-4 leading-relaxed">現在、定期的なレッスンは開講されていません。当施設はインドアのシミュレーションゴルフ施設です。</p>
                    </details>
                    <details class="faq-details group border rounded-lg bg-slate-50 p-4 overflow-hidden transition-all duration-300">
                        <summary class="font-bold cursor-pointer flex justify-between items-center">Q. 初心者がいきなりプロに習っても大丈夫？<span class="text-green-600 transition group-open:rotate-180">▼</span></summary>
                        <p class="mt-4 text-sm text-slate-600 border-t pt-4 leading-relaxed">むしろ初心者のうちに習うのが最短ルートです。変な癖がつく前に学ぶことで、将来の練習代を節約できます。</p>
                    </details>
                 </div>
            </section>
            
            {/* --- 基本情報まとめ（最も丁寧な表形式） --- */}
            <section id="info-summary" class="mt-12 pt-6 border-t border-slate-200 scroll-mt-24">
                 <h2 class="text-2xl md:text-3xl font-bold text-slate-800">各施設の基本情報・アクセスまとめ</h2>
                 <div class="space-y-12 mt-4">
                     {rangeIds.map(id => {
                         const range = rangesData[id];
                         if (!range) return null;
                         const avgRating = range.avgRating || 0;
                         const reviewCount = range.reviewCount || 0;
                         const searchQuery = encodeURIComponent(`${range.name}, ${range.address}`);
                         const mapsEmbedUrl = `https://www.google.com/maps/embed/v1/place?key=${gmapsApiKey}&q=${searchQuery}`;

                         return (
                             <div id={`info-${id}`} class="scroll-mt-24 bg-slate-50 p-6 rounded-xl border border-slate-200 shadow-sm">
                                 <h3 class="text-xl font-bold flex items-center flex-wrap gap-x-2 gap-y-1">
                                    <a href={additionalData[id].rangeUrl} class="text-green-800 hover:underline">{range.name}</a>
                                    <span class="text-amber-400 text-base font-bold">★ {avgRating > 0 ? avgRating.toFixed(1) : '-'} <small class="text-slate-500 font-normal">({reviewCount}件)</small></span>
                                 </h3>
                                 <div class="not-prose overflow-x-auto mt-4 text-sm">
                                     <table class="w-full text-left border-collapse bg-white"><tbody>
                                         <tr class="border-b"><th class="py-3 px-4 bg-slate-50 font-semibold w-1/3 text-left">住所</th><td class="py-3 px-4">{range.address}</td></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-slate-50 font-semibold text-left">アクセス</th><td class="py-3 px-4">{additionalData[id].access}</td></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-slate-50 font-semibold text-left">電話番号</th><td class="py-3 px-4">{range.phone || '-'}</td></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-slate-50 font-semibold text-left">規模</th><td class="py-3 px-4">{range.yardage ? `${range.yardage}yd` : 'インドア'} / {range.bays}席</td></tr>
                                     </tbody></table>
                                 </div>
                                 <iframe src={mapsEmbedUrl} width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy" class="rounded-lg mt-4 border border-slate-200"></iframe>
                             </div>
                         )
                     })}
                 </div>
            </section>

            <ShareButtons articleUrl={articleUrl} headline={headline} />
            <div class="not-prose my-12 space-y-12">
                <MySlider articles={experienceReports} title="あわせて読みたい「体験レポート」"/>
                <MySlider articles={comparisonArticles} title="滋賀のゴルフ練習場 比較記事一覧"/>
            </div>
            <AuthorProfile />
        </article>
    </div>
</BaseLayout>