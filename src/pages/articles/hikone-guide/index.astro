    {/* =======================================================
        専用 VS料金シミュレーター JavaScript (簡易版)
    ======================================================== */}
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const simulator = document.getElementById('vs-hikone-simulator');
        if (!simulator) return;

        const memSel = document.getElementById('vs-h-member');
        const daySel = document.getElementById('vs-h-day');
        const ballSlider = document.getElementById('vs-h-ball-slider');
        const ballDisplay = document.getElementById('vs-h-ball-display');

        const resKsp = document.getElementById('vs-h-res-ksp');
        const noteKsp = document.getElementById('vs-h-note-ksp');
        const res365 = document.getElementById('vs-h-res-365');
        const note365 = document.getElementById('vs-h-note-365');

        function calculate() {
            const isMem = memSel.value === "member";
            const day = daySel.value; // weekday, weekend
            const balls = parseInt(ballSlider.value);
            ballDisplay.textContent = `${balls}球`;

            // --- KSPの計算（簡易概算） ---
            // 入場料
            let kEntry = (day === 'weekday') ? 220 : 275;
            // ボール代 (1F通常時間帯)
            let kBallPt = (day === 'weekday') ? 8.8 : 9.9;
            // 還元処理: 一般は1球1pt還元、チャージ還元率約4% (0.961)
            let kUsedPt = kEntry + (kBallPt * balls) - balls; 
            let kTotal = Math.ceil(kUsedPt * 0.961);
            
            resKsp.textContent = `¥${kTotal.toLocaleString()}`;
            noteKsp.innerHTML = `入場料${kEntry}円 + 実質単価${(kBallPt-1).toFixed(1)}pt<br><span class="text-emerald-300 font-bold">(※ふるさと納税を使えば実質0円に！)</span>`;

            // --- 365の計算（簡易概算） ---
            // 入場料
            let sEntry = isMem ? 0 : 250;
            // ボール代 (1F通常時間帯)
            let sBallPt = 0;
            if(isMem) sBallPt = (day === 'weekday') ? 7 : 9;
            else sBallPt = (day === 'weekday') ? 10 : 11;
            
            // ポイント単価 (ビジター1.1円, メンバー1.0円として計算)
            let sRate = isMem ? 1.0 : 1.1;
            let sTotal = sEntry + Math.ceil(sBallPt * balls * sRate);

            res365.textContent = `¥${sTotal.toLocaleString()}`;
            note365.innerHTML = `入場料${sEntry}円 + 単価${sBallPt}pt<br><span class="text-orange-300 font-bold">(※LINE割・女性割などで更に安くなります)</span>`;
        }

        [memSel, daySel].forEach(el => el.addEventListener('change', calculate));
        ballSlider.addEventListener('input', calculate);
        calculate();
    });
    </script>
