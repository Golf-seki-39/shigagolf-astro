                ladies_day: [
                    { name: "【ペア1人分】1時間打ち放題", price: 1000 },
                    { name: "【ペア1人分】2時間打ち放題", price: 1600 }
                ]
            }
        };

        // --- 要素取得 ---
        const planSelect = simulator.querySelector('#plan-select');
        const dayRadios = simulator.querySelectorAll('input[name="day"]');
        const floorRadios = simulator.querySelectorAll('input[name="floor"]');
        const timeRadios = simulator.querySelectorAll('input[name="time"]');
        const ballCountSlider = simulator.querySelector('#ball-count');
        const ballCountDisplay = simulator.querySelector('#ball-count-display');
        const totalPriceDisplay = simulator.querySelector('#total-price');
        const unlimitedDisplay = simulator.querySelector('#unlimited-display');
        const pairNotice = simulator.querySelector('#pair-notice');
        const quickBtns = simulator.querySelectorAll('.quick-ball-btn'); 

        // --- 計算関数 ---
        function calculatePrice() {
            const plan = planSelect.value;
            
            // 全ての必須項目が選ばれるまでは金額を表示しない（----のまま）
            if (!plan) return;

            // レディースデー強制設定と強調表示
            if (plan === 'ladies_day') {
                simulator.querySelector('input[name="day"][value="weekday"]').checked = true;
                pairNotice.classList.remove('hidden'); 
            } else {
                pairNotice.classList.add('hidden');
            }

            const dayEl = simulator.querySelector('input[name="day"]:checked');
            const floorEl = simulator.querySelector('input[name="floor"]:checked');
            const timeEl = simulator.querySelector('input[name="time"]:checked');

            // 必須項目チェック
            if (!dayEl || !floorEl || !timeEl) {
                totalPriceDisplay.textContent = "----";
                unlimitedDisplay.classList.add('hidden');
                return;
            }

            const day = dayEl.value;
            const floor = floorEl.value;
            const time = timeEl.value;
            const balls = parseInt(ballCountSlider.value);

            ballCountDisplay.textContent = `${balls}球`;

            // 単価計算
            const basePlan = plan === 'ladies_day' ? 'visitor' : plan;
            const entryFee = plan === 'ladies_day' ? 0 : priceData.entry[basePlan]; 
            const ballPrice = priceData.balls[day][time][floor][basePlan];
            
            const ballTotal = entryFee + (ballPrice * balls);

            // 打ち放題との比較
            unlimitedDisplay.classList.add('hidden');
            unlimitedDisplay.innerHTML = ""; 

            let bestOption = { name: '単価打ち', price: ballTotal };
            let unlimitedMessage = "";
            let availablePlans = [];

            if (plan === 'ladies_day') {
                availablePlans = priceData.unlimited.ladies_day;
            } else if (day === 'weekday') {
                availablePlans = priceData.unlimited.weekday;
            } else {
                availablePlans = priceData.unlimited.weekend;
            }

            // 打ち放題プランの提示
            if (availablePlans.length > 0) {
                const cheapestUnlimited = availablePlans.reduce((min, p) => p.price < min.price ? p : min, availablePlans[0]);
                
                if (cheapestUnlimited.price <= ballTotal || plan === 'ladies_day') {
                    bestOption = cheapestUnlimited;
                    unlimitedMessage = "💡 おすすめ打ち放題プラン:<br>" + availablePlans.map(p => {
                        return `${p.name} (¥${p.price.toLocaleString()})`;
                    }).join('<br>');
                }
            }
            
            // 結果表示
            let finalPriceString = bestOption.price.toLocaleString();
            
            if (bestOption.name !== '単価打ち') {
                finalPriceString = `${finalPriceString}〜`; 
            }

            totalPriceDisplay.textContent = finalPriceString;
            
            if (unlimitedMessage) {
                unlimitedDisplay.innerHTML = unlimitedMessage;
                unlimitedDisplay.classList.remove('hidden');
            }
        }

        // --- イベントリスナー ---
        planSelect.addEventListener('change', calculatePrice);
        dayRadios.forEach(radio => radio.addEventListener('change', calculatePrice));
        floorRadios.forEach(radio => radio.addEventListener('change', calculatePrice));
        timeRadios.forEach(radio => radio.addEventListener('change', calculatePrice));
        ballCountSlider.addEventListener('input', calculatePrice);
        
        // クイックボタンのイベントリスナー
        quickBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const target = e.target;
                ballCountSlider.value = target.dataset.value;
                calculatePrice();
            });
        });

        // 初期計算（初期状態は空なので計算は走るが金額は更新されない）
        calculatePrice();
    });
    </script>
</BaseLayout>