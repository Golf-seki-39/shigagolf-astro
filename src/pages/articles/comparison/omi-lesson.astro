            <ShareButtons articleUrl={articleUrl} headline={headline} />

            <div class="not-prose my-12 space-y-12">
                <MySlider articles={experienceReports} title="あわせて読みたい「体験レポート」"/>
                <MySlider articles={comparisonArticles} title="滋賀のゴルフ練習場 比較記事一覧"/>
            </div>
            <AuthorProfile />
            
            {/* --- 各施設の情報まとめ --- */}
            <section id="info-summary" class="mt-12 pt-6 border-t border-slate-200 scroll-mt-24">
                 <h2 class="text-2xl md:text-3xl font-bold text-slate-800">各施設の基本情報まとめ</h2>
                 <div class="space-y-12 mt-4">
                     {rangeIds.map(id => {
                         const range = rangesData[id];
                         if (!range) return null;
                         const avgRating = range.avgRating || 0;
                         const reviewCount = range.reviewCount || 0;
                         const searchQuery = encodeURIComponent(`${range.name}, ${range.address}`);
                         const mapsEmbedUrl = `https://www.google.com/maps/embed/v1/place?key=${gmapsApiKey}&q=${searchQuery}`;

                         return (
                             <div id={id} class="scroll-mt-24 bg-slate-50 p-6 rounded-xl border border-slate-200 shadow-sm">
                                 <h3 class="text-xl font-bold flex items-center flex-wrap gap-x-2 gap-y-1">
                                    <a href={additionalData[id].rangeUrl} class="text-green-800 hover:underline">{range.name}</a>
                                    <div class="flex items-center text-amber-400 text-base">
                                        ★ {avgRating > 0 ? avgRating.toFixed(1) : '-'}
                                        <span class="text-sm text-slate-500 font-normal ml-1">({reviewCount}件)</span>
                                    </div>
                                 </h3>
                                 <div class="not-prose overflow-x-auto mt-4">
                                     <table class="w-full text-left border-collapse text-sm"><tbody>
                                         <tr class="border-b"><th class="py-3 px-4 bg-white font-semibold w-1/3">住所</th><td class="py-3 px-4">{range.address}</td></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-white font-semibold">アクセス</th><td class="py-3 px-4">{additionalData?.[id]?.access || '-'}</td></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-white font-semibold">電話番号</th><td class="py-3 px-4">{range.phone ? <a href={`tel:${range.phone.replace(/-/g, "")}`} class="text-blue-600 hover:underline">{range.phone}</a> : '-'}</td></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-white font-semibold">営業時間</th><td class="py-3 px-4" set:html={range.business_hours?.replace(/\n/g, '<br />') || '-'} /></tr>
                                         <tr class="border-b"><th class="py-3 px-4 bg-white font-semibold">ヤード数</th><td class="py-3 px-4">{range.yardage ? `${range.yardage}yd` : 'インドア'}</td></tr>
                                         <tr><th class="py-3 px-4 bg-white font-semibold">打席数</th><td class="py-3 px-4">{range.bays ? `${range.bays}席` : '-'}</td></tr>
                                     </tbody></table>
                                 </div>
                                 <div class="not-prose mt-6 flex flex-col items-center gap-4">
                                     <a href={additionalData[id].rangeUrl} class="w-full max-w-md inline-flex items-center justify-center bg-green-700 text-white font-bold py-3 px-6 rounded-lg no-underline btn-shadow hover:bg-green-800 transition-all">
                                        練習場の詳細情報を見る
                                     </a>
                                     <iframe src={mapsEmbedUrl} width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy" class="rounded-lg shadow-sm border border-slate-200"></iframe>
                                 </div>
                             </div>
                         )
                     })}
                 </div>
            </section>

        </article>
    </div>
</BaseLayout>