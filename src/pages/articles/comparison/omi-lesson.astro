---import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

// --- 共通コンポーネント ---
import MySlider from '../../../components/MySlider.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';

// --- この記事固有の情報 ---
const baseUrl = "https://shigagolf.com";
const articleUrl = `${baseUrl}/articles/comparison/omi-lesson/`;
const publicationDate = "2025-10-12";
const lastModified = new Date();

// --- SEO対策：評判・プロ・初心者・格安を網羅 ---
const title = "【滋賀ゴルフレッスン評判】プロの質と安さで比較！初心者おすすめ4選【近江八幡・東近江】";
const description = "滋賀県（近江八幡・東近江）で評判の良いゴルフレッスンを徹底比較。実際に挫折を経験した管理人が「プロの質」「安さ」「初心者への優しさ」をデメリットまで含めて本音でレビュー。失敗しないための防衛マニュアルです。";
const headline = "【実体験】滋賀のゴルフレッスン選びで失敗しない！初心者におすすめの評判プロ・スクール4選";
const imageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (12).jpg";

// --- Firebaseデータ取得 ---
const rangeIds = ['riverside_jumbo', 'greenpia_oh', 'sakura_gc', 'azuchi_gc'];
const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const rangePromises = rangeIds.map(id => getDoc(doc(db, `artifacts/${appId}/public/data/practice_ranges/${id}`)));
const rangeDocs = await Promise.all(rangePromises);

const rangesData = rangeDocs.reduce((acc, docSnap, index) => {
    if (docSnap.exists()) { acc[rangeIds[index]] = docSnap.data(); }
    else { acc[rangeIds[index]] = null; }
    return acc;
}, {});

if (rangesData.greenpia_oh) {
    rangesData.greenpia_oh.name = "グリーンピア近江八幡ゴルフ";
}

// --- 比較表・施設リンクデータ ---
const summaryData = [
    { type: '格安で基本を学びたい', id: 'riverside_jumbo', format: 'グループ', fee: '<strong class="text-red-600">実質200円</strong>', feature: '挫折しようがない、初心者のための最高の入口。' },
    { type: '本気で上達したい', id: 'azuchi_gc', format: '<strong>マンツーマン</strong>', fee: '4,000円', feature: '遠方からも人が集う質の高いレッスン。自己流から脱却したいならココ。' },
    { type: '女性プロに安心して習いたい', id: 'sakura_gc', format: 'グループ or<br/>マンツーマン', fee: '1,000円〜', feature: '女性プロが2名在籍。初回割引もあり、女性や初心者が試しやすい環境。' },
    { type: '多くのプロから選びたい', id: 'greenpia_oh', format: '多種多様', fee: '1,200円〜', feature: 'まさに「レッスンのデパート」。どんなニーズにも応える圧倒的な選択肢。' }
];

const additionalData = {
    riverside_jumbo: { 
        reviewUrl: '/articles/review/riverside-jumbo/', 
        rangeUrl: '/ranges/riverside_jumbo/',
        access: '名神八日市ICから車で10分' 
    },
    azuchi_gc: { 
        reviewUrl: '/articles/azuchi-review/', 
        rangeUrl: '/ranges/azuchi_gc/',
        access: 'JR安土駅から車で5分' 
    },
    sakura_gc: { 
        reviewUrl: '/articles/sakura-gc-review/', 
        rangeUrl: '/ranges/sakura_gc/',
        access: '名神竜王ICから車で15分' 
    },
    greenpia_oh: { 
        reviewUrl: '/articles/review/greenpia-oh/', 
        rangeUrl: '/ranges/greenpia_oh/',
        access: '名神竜王ICから車で10分' 
    },
};

// --- JSON-LD構造化データ（完全版） ---
const mainEntity = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
    "headline": headline, 
    "description": description, 
    "image": [
        imageUrl,
        "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/C7A324E8-9569-4216-8955-2B3F2D9B59112025-04-02_18-42-15_481.jpg",
        "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/WcDqIqT.jpeg",
        "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_6245.jpeg",
        "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8072 2.png"
    ],
    "author": { "@type": "Person", "name": "関（シガゴル運営者）", "url": `${baseUrl}/about/` },
    "publisher": { "@type": "Organization", "name": "シガゴル", "logo": { "@type": "ImageObject", "url": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/logo.png" }},
    "datePublished": new Date(publicationDate).toISOString(), 
    "dateModified": lastModified.toISOString()
};

const faqElements = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": articleUrl + "#faq",
  "mainEntity": [
    { "@type": "Question", "name": "滋賀で評判の良いゴルフレッスンはどこ？", "acceptedAnswer": { "@type": "Answer", "text": "安土ゴルフクラブの入江プロによるマンツーマンレッスンや、リバーサイドジャンボゴルフの初心者スクールが口コミ・評判ともに非常に高いです。" } },
    { "@type": "Question", "name": "初心者が失敗しないレッスンの選び方は？", "acceptedAnswer": { "@type": "Answer", "text": "まずは体験レッスンでプロとの相性を確認し、初心者専用クラスがあるスクールを選ぶのが安心です。特に滋賀ではリバーサイドジャンボの初心者スクールが人気です。" } },
    { "@type": "Question", "name": "がれーじぱーく東近江はレッスンをやってる？", "acceptedAnswer": { "@type": "Answer", "text": "現在、がれーじぱーく東近江ではゴルフレッスンは開講されていません。当施設はインドアのシミュレーションゴルフ施設となります。指導を希望される方は本記事紹介の4施設がスムーズです。" } },
    { "@type": "Question", "name": "プロのレッスンを受ける際、クラブは必要？", "acceptedAnswer": { "@type": "Answer", "text": "多くのスクールで無料レンタル可能です。最初から高価なセットを買う必要はありません。まずは手ぶらでプロに教わるのが賢い選択です。" } },
    { "@type": "Question", "name": "滋賀で一番「安い」レッスンはどこ？", "acceptedAnswer": { "@type": "Answer", "text": "圧倒的にリバーサイドジャンボゴルフの初心者スクールです。登録料のみで実質4回分が無料になる仕組みは他にはありません。" } }
  ]
};

// --- 関連記事リスト ---
const experienceReports = [
    { url: '/articles/azuchi-review/', title: '安土ゴルフクラブ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/0000image0000.png' },
    { url: '/articles/sakura-gc-review/', title: 'さくらゴルフ倶楽部 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/00000ai.png' },
    { url: '/articles/garege-park-review/', title: 'がれーじぱーく東近江 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/00000ai.jpg' },
    { url: '/articles/review/greenpia-oh/', title: 'グリーンピア近江八幡ゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/シガゴル (14).jpg' },
    { url: '/articles/review/riverside-jumbo/', title: 'リバーサイドジャンボゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/シガゴル (15).jpg' },
];

const comparisonArticles = [
    { url: '/articles/comparison/omi-pricerank/', title: '【料金で徹底比較】近江八幡・東近江の安い練習場5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (2).jpg' },
    { url: '/articles/omi-higashiomi-approach/', title: '【アプローチ＆バンカー練習場】近江八幡・東近江5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/approach.jpg' },
    { url: '/articles/comparison/omi-putting/', title: '【パター練習場が充実】近江八幡・東近江エリア5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル.jpg' },
    { url: '/articles/comparison/omi-lesson/', title: '【レッスン比較】近江八幡・東近江の初心者向け4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (12).jpg' },
    { url: '/articles/comparison/higashiomi-guide/', title: '【2025年最新】東近江市のゴルフ練習場まとめ｜全3施設を料金・設備で徹底比較', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (14).jpg' },
    { url: '/articles/comparison/o-mihachiman-guide/', title: '【近江八幡 打ちっぱなし】グリーンピア vs 安土 結局どっち？料金・質・アクセスを現地ライターが本音で徹底比較 ', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/hachiman-guide.jpg' },
    { url: '/articles/comparison/omi-higashiomi-comparison/', title: '【総合比較】近江八幡・東近江エリアのゴルフ練習場4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/ナイスミス (9).png' },
];

const gmapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<BaseLayout title={title} description={description} pubDate={publicationDate} ogImage={imageUrl}>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(mainEntity)} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqElements)} />
    
    <div id="article-view" class="view bg-white p-6 md:p-8 rounded-lg shadow-lg max-w-4xl mx-auto">
        <a href="/articles/" class="nav-link back-button mb-6 text-green-700 font-semibold hover:underline">
            ‹ お役立ち記事一覧に戻る
        </a>
        <article class="prose lg:prose-xl max-w-none text-slate-700 leading-relaxed">
            <style>
              html { scroll-behavior: smooth; }
              section[id] { scroll-margin-top: 80px; }
              .faq-details summary::-webkit-details-marker { display: none; }
              .faq-details summary { list-style: none; outline: none; }
              .no-wrap { white-space: nowrap; }
              .btn-shadow { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
           /* 専門用語の下線と注釈の設定 */
.term-tip { 
    border-bottom: 2px dotted #059669; 
    cursor: help; 
    position: relative; 
    display: inline-block; 
    font-weight: bold; 
    color: #064e3b; 
}

.term-tip:hover::after { 
    content: attr(data-tip); 
    position: absolute; 
    bottom: 125%; 
    
    /* --- ここから修正 --- */
    left: 0; /* 中央寄せをやめ、左端を基準にするんだ */
    transform: none; /* 中央寄せの計算を解除 */
    
    /* 画面からはみ出さないための設定 */
    width: 80vw; /* スマホ画面幅の80%を最大値にする */
    max-width: 280px; /* PCで見ても広がりすぎないように制限 */
    /* --- ここまで修正 --- */

    background: #1e293b; 
    color: #fff; 
    padding: 10px 14px; /* 少し余裕を持たせる */
    border-radius: 6px; 
    font-size: 0.8rem; 
    line-height: 1.5; 
    z-index: 50; 
    white-space: normal; 
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
}
            </style>
                        
            <header>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-800">{headline}</h1>
                <p class="text-sm text-slate-500 mt-2">最終更新日：{lastModified.getFullYear()}-{String(lastModified.getMonth() + 1).padStart(2, '0')}-{String(lastModified.getDate()).padStart(2, '0')}</p>
            </header>

            <Image src={imageUrl} alt="滋賀のゴルフ初心者向けレッスン評判比較" class="w-full h-auto object-cover rounded-lg my-6" width={1200} height={675} fetchpriority="high" />

            {/* --- 【Plan A】目的別・結論ボックス --- */}
            <div class="not-prose bg-gray-50 p-6 rounded-lg border-2 border-green-600 shadow-sm my-8">
                <h3 class="text-xl font-bold text-slate-800 mb-4 text-center">👇 滋賀のゴルフレッスン 評判・目的別の結論 👇</h3>
                <ul class="space-y-3">
                    <li class="flex items-start">
                        <span class="text-2xl mr-2">💰</span>
                        <div>
                            <span class="font-bold text-slate-800 block">とにかく格安で始めたいなら</span>
                            <a href="#riverside_jumbo" class="text-blue-600 font-bold underline hover:text-blue-800">リバーサイドジャンボゴルフ</a> <span class="text-red-600 font-bold text-sm">(実質200円)</span>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <span class="text-2xl mr-2">🏌️</span>
                        <div>
                            <span class="font-bold text-slate-800 block">プロの質（マンツーマン）重視なら</span>
                            <a href="#azuchi_gc" class="text-blue-600 font-bold underline hover:text-blue-800">安土ゴルフクラブ</a> <span class="text-sm text-slate-600">(入江プロの本格指導)</span>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <span class="text-2xl mr-2">👩</span>
                        <div>
                            <span class="font-bold text-slate-800 block">女性プロ在籍・安心感で選ぶなら</span>
                            <a href="#sakura_gc" class="text-blue-600 font-bold underline hover:text-blue-800">さくらゴルフ倶楽部</a> <span class="text-sm text-slate-600">(女性コーチ2名在籍)</span>
                        </div>
                    </li>
                </ul>
            </div>

            <p><strong>【告白】私は一度、ゴルフレッスンで心を折られました。</strong></p>
            <p>ゴルフを始めてすぐの頃、「そんなことも知らないの？」と言いたげなプロの態度に、私の心はポッキリと折れました。「グリップの握り方すら分からないのに…」そう感じたあの日以来、私はレッスンから距離を置き、遠回りを承知で独学の道を選んできたのです。</p>
            <p>だからこそ、この記事は単なる情報の羅列ではありません。過去の私と同じように、レッスン選びに不安を感じているあなたが、<strong>お金と時間を無駄にせず、最高のゴルフライフの第一歩を踏み出すための「防衛マニュアル」</strong>です。良いところだけでなく、デメリットも本音で書きました。</p>
            
            <div class="not-prose bg-blue-50 p-6 rounded-lg my-8 border-l-4 border-blue-500 text-blue-900">
    <p class="font-bold mt-0 flex items-center">❄️ 滋賀の冬、独学は「サボり」の始まり？</p>
    <p class="mb-0 text-sm md:text-base leading-relaxed">
        滋賀の冬は寒さが厳しく、一人だとつい練習をサボりがちですよね。だからこそ、<strong>予約制のレッスンを入れて「サボれない環境」を強制的に作る</strong>のも、上達への賢い戦略です。冬の間にプロと二人三脚で土台を作っておけば、春のシーズンには見違えるスイングになっていますよ。
    </p>
</div>

            <p class="text-sm text-slate-600">※近江八幡・東近江エリアには5つのゴルフ練習場がありますが、この記事ではレッスンを開講している4施設に絞って徹底比較します。「がれーじぱーく東近江」は現在レッスンを開講していないため、今回は比較の対象外としています。</p>

            {/* --- 比較表セクション --- */}
            <section id="summary-table">
                <h2 class="text-2xl font-bold mt-8 pt-4 border-t border-slate-200">【比較表】滋賀で自分に合うゴルフレッスンを探す診断表</h2>
                <p>👇 まずは全体像から。あなたの目的にピッタリの練習場がひと目で分かります。</p>
                
                <div class="overflow-x-auto my-4 not-prose hidden md:block">
                    <style>.no-wrap { white-space: nowrap; }</style>
                    <table class="w-full text-sm text-left border border-slate-300 min-w-table">
                        <thead class="bg-slate-100">
                            <tr>
                                <th class="px-4 py-3 border border-slate-300 align-middle">あなたの目的</th>
                                <th class="px-4 py-3 border border-slate-300 align-middle">おすすめ練習場</th>
                                <th class="px-4 py-3 border border-slate-300 text-center">形式</th>
                                <th class="px-4 py-3 border border-slate-300 text-center no-wrap">初回料金目安</th>
                                <th class="px-4 py-3 border border-slate-300 align-middle">最大の特徴</th>
                            </tr>
                        </thead>
                        <tbody>
                            {summaryData.map((item, index) => (
                                <tr class={(index % 2 !== 0) ? 'bg-slate-50' : 'bg-white'}>
                                    <td class="px-4 py-2 border align-middle font-semibold no-wrap">{item.type}</td>
                                    <td class="px-4 py-2 border align-middle font-semibold no-wrap"><a href={`#${item.id}`} class="text-blue-600 hover:underline">{rangesData[item.id]?.name}</a></td>
                                    <td class="px-4 py-2 border text-center align-middle no-wrap" set:html={item.format} />
                                    <td class="px-4 py-2 border text-center align-middle no-wrap" set:html={item.fee} />
                                    <td class="px-4 py-2 border align-middle text-xs">{item.feature}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>

                <div class="space-y-4 my-4 md:hidden not-prose">
                    {summaryData.map(item => (
                        <div class="border rounded-lg p-4 bg-white shadow-sm border-l-4 border-l-green-600">
                            <h4 class="text-xs font-bold m-0 text-slate-500 uppercase tracking-wider">{item.type}</h4>
                            <h3 class="text-lg font-bold my-1"><a href={`#${item.id}`} class="text-blue-600 underline">{rangesData[item.id]?.name}</a></h3>
                            <div class="text-sm mt-2 border-t pt-2 space-y-1">
                                <div class="flex justify-between"><span>形式: <strong set:html={item.format.replace('<br/>',' ')} /></span><span>料金: <strong class="text-red-600" set:html={item.fee} /></span></div>
                                <p class="text-xs text-slate-600 mt-1 leading-tight">特徴: {item.feature}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

         {/* --- 個別レビューセクション --- */}
            <section id="review-details">
                 <h2 class="text-2xl font-bold mt-8 pt-4 border-t border-slate-200">【実体験】滋賀県内4つのゴルフレッスン徹底レビュー</h2>
                 
                 {/* リバーサイドジャンボ */}
                 <div id="riverside_jumbo" class="mt-8 border-t border-slate-200 pt-6 scroll-mt-24">
                     <h3 class="text-2xl font-bold text-slate-800 mt-0"><a href="/ranges/riverside_jumbo/" class="text-green-700 hover:underline">リバーサイドジャンボゴルフ</a></h3>
                     <h4 class="text-xl font-semibold text-slate-600 italic">挫折した僕が教えたい、最高の”入口”</h4>
                     <p>東近江エリアで「何から手をつけていいか全く分からない」方に、私が心の底からお勧めするのが、この<strong>「初心者スクール」</strong>です。担当の砂川プロの人柄がとにかく温厚。最大の魅力は<strong>実質200円</strong>という安さで、手ぶらで基礎を学べます。</p>
                     <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/C7A324E8-9569-4216-8955-2B3F2D9B59112025-04-02_18-42-15_481.jpg" alt="滋賀県東近江市のリバーサイドジャンボゴルフで行われている初心者向けレッスンの看板" class="w-full h-auto object-cover rounded-lg my-4" />
                     <div class="bg-red-50 p-4 rounded-lg border-l-4 border-red-500 my-4 text-sm">
                        <p class="font-bold text-red-700 mb-1">⚠️ デメリット・注意点</p>
