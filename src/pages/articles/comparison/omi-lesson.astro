                        <a href={additionalData.greenpia_oh.rangeUrl} class="w-full md:w-auto inline-flex items-center justify-center bg-green-700 text-white font-bold py-3 px-8 rounded-lg no-underline btn-shadow hover:bg-green-800 transition-all">練習場の詳細情報を見る</a>
