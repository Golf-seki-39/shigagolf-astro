    <script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. 横長テーブル表示切り替えロジック (A案の移植) ---
        const toggleButtons = document.querySelectorAll('.view-toggle-btn');
        toggleButtons.forEach(button => {
            button.addEventListener('click', () => {
                const targetId = button.dataset.targetId;
                const tableContainer = document.getElementById(targetId);
                if (!tableContainer) return;

                tableContainer.classList.toggle('show-table-view');
                const isTableView = tableContainer.classList.contains('show-table-view');
                if (isTableView) {
                    button.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M4 3a1 1 0 00-1 1v12a1 1 0 001 1h12a1 1 0 001-1V4a1 1 0 00-1-1H4zm3 2h6v4H7V5zm0 6h6v2H7v-2z" />
                        </svg>
                        カード表示に戻す`;
                } else {
                    button.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                        </svg>
                        画面を横にして一覧表で見る`;
                }
            });
        });

        // --- 2. 最安値一括シミュレーターロジック (B案) ---
        const simulator = document.getElementById('area-price-simulator');
        if (!simulator) return;

        const userTypeSel = document.getElementById('sim-user-type');
        const daySel = document.getElementById('sim-day');
        const timeSel = document.getElementById('sim-time-slot');
        const floorRadios = document.getElementsByName('sim-floor');
        const ballSlider = document.getElementById('sim-ball-slider');
        const ballDisplay = document.getElementById('sim-ball-display');
        const resultsContainer = document.getElementById('sim-results');
        const quickBtns = document.querySelectorAll('.sim-quick-btn');

        function getRequiredHours(balls) {
            if (balls <= 100) return 1;
            if (balls <= 200) return 2;
            return 3;
        }

        function getCheapestPlan(unitTotal, timePlans, reqHours) {
            let best = { price: unitTotal, isTimePlan: false, name: '' };
            for (let plan of timePlans) {
                if (reqHours <= plan.hours && plan.price < best.price) {
                    best = { price: plan.price, isTimePlan: true, name: plan.name };
                }
            }
            return best;
        }

        function calculateAll() {
            const userType = userTypeSel.value; 
            const isMember = userType.startsWith('member');
            const isFemale = userType.endsWith('_f');
            const isJr = userType === 'junior';
            
            const day = daySel.value; 
            const isWeekend = (day === 'weekend');
            const isWeekday = !isWeekend;
            
            const time = timeSel.value; 
            const checkedFloorInput = document.querySelector('input[name="sim-floor"]:checked');
            const floor = checkedFloorInput ? checkedFloorInput.value : '2F';
            const balls = parseInt(ballSlider.value);
            const reqHours = getRequiredHours(balls);

            ballDisplay.textContent = `${balls}球`;

            let results = [];

            // [グリーンピア近江八幡]
            let gpEntry = (time === 't6_9' || (time === 't9_12' && isMember)) ? 0 : 300; 
            if(isMember) gpEntry = 0;
            let gpBallPrice = 0;
            if(time === 't6_9') gpBallPrice = 6;
            else if (time === 't9_12' || time === 't12_17') {
                gpBallPrice = isWeekend ? (floor === '1F' ? 9 : 7) : (floor === '1F' ? 8 : 5);
            } else { 
                gpBallPrice = isWeekend ? (floor === '1F' ? 9 : 7) : (floor === '1F' ? 9 : 5);
            }
            let gpUnitTotal = gpEntry + (gpBallPrice * balls);
            let gpPlans = [];
            if(isFemale || isJr) {
                gpPlans.push({ hours: 1, price: 550, name: '1時間打ち放題' });
                gpPlans.push({ hours: 2, price: 1100, name: '2時間打ち放題' });
                gpPlans.push({ hours: 3, price: 1650, name: '3時間打ち放題' });
            } else {
                gpPlans.push({ hours: 3, price: isWeekend ? 2200 : 1980, name: '3時間打ち放題' });
            }
            let gpBest = getCheapestPlan(gpUnitTotal, gpPlans, reqHours);
            let gpNote = gpBest.isTimePlan ? `<span class="text-pink-400 font-bold text-xs">※${gpBest.name}</span>` : `(単価${gpBallPrice}円+入場料${gpEntry}円)`;
            if(!gpBest.isTimePlan && isWeekday && floor === '2F' && time !== 't6_9') gpNote += `<br><span class="text-yellow-300 text-xs">★平日2階は単価5円で激安！</span>`;
            results.push({ id: 'greenpia_oh', name: 'グリーンピア近江八幡', price: gpBest.price, feature: '平日・たくさん打つなら◎', note: gpNote, color: 'bg-green-600' });

            // [さくらゴルフ倶楽部]
            let skEntry = 0;
            if (time !== 't6_9' && time !== 't22_24' && !isMember && !isFemale && !isJr) {
                skEntry = isWeekend ? 320 : 280;
            }
            let skBallPrice = 0;
            if (time === 't6_9') skBallPrice = 7;
            else if (time === 't9_12' || time === 't12_17') skBallPrice = isWeekend ? (floor === '1F' ? 10 : 9) : 8;
            else if (time === 't17_22') skBallPrice = 9;
            else if (time === 't22_24') skBallPrice = 8;
            if (isMember && time !== 't6_9' && time !== 't22_24') skBallPrice -= 1;
            let skUnitTotal = skEntry + (skBallPrice * balls);
            let skPlans = [];
            if (time !== 't6_9' && time !== 't22_24') {
                if (isFemale || isJr) {
                    skPlans.push({ hours: 1, price: 515, name: '1時間打ち放題' });
                    skPlans.push({ hours: 2, price: 1030, name: '2時間打ち放題' });
                    skPlans.push({ hours: 3, price: 1545, name: '3時間打ち放題' });
                } else if (isMember) {
                    skPlans.push({ hours: 2, price: 1030, name: '2時間打ち放題' });
                    skPlans.push({ hours: 3, price: 1545, name: '3時間打ち放題' });
                } else {
                    skPlans.push({ hours: 3, price: isWeekend ? 2060 : 1854, name: '3時間打ち放題' });
                }
            }
            let skBest = getCheapestPlan(skUnitTotal, skPlans, reqHours);
            let skNote = skBest.isTimePlan ? `<span class="text-pink-400 font-bold text-xs">※${skBest.name}</span>` : `(単価${skBallPrice}円+入場料${skEntry}円)`;
            if(isFemale || isJr) skNote += `<br><span class="text-pink-300 text-xs">★女性・ジュニア特権適用！</span>`;
            results.push({ id: 'sakura_gc', name: 'さくらゴルフ倶楽部', price: skBest.price, feature: '女性・ジュニア・冷房完備', note: skNote, color: 'bg-rose-500' });

            // [安土ゴルフクラブ]
            let azKagoCount = Math.ceil(balls / 100);
            let isAzLadiesDay = isFemale && (day === 'mon_fri' || day === 'wed') && (time === 't9_12' || time === 't12_17');
            let azKagoPrice = isAzLadiesDay ? 600 : ((isMember || isFemale || isJr) ? 600 : 700);
            let azUnitTotal = azKagoCount * azKagoPrice;
            let azPlans = [];
            if (time === 't17_22' || time === 't22_24') {
                azPlans.push({ hours: 3, price: (isMember || isFemale || isJr) ? 1000 : 1200, name: 'ナイター(300球迄)' });
            } else if (time === 't9_12' || time === 't12_17') {
                if (isAzLadiesDay) {
                    azPlans.push({ hours: 2, price: 600, name: 'LD 2h打ち放題' });
                    azPlans.push({ hours: 3, price: 600, name: 'LD 3h打ち放題' });
                } else {
                    azPlans.push({ hours: 2, price: (isMember || isFemale || isJr) ? 1000 : 1200, name: '2時間打ち放題' });
                    azPlans.push({ hours: 3, price: (userType==='member_m') ? 1300 : ((isFemale || isJr) ? 1000 : 1500), name: '3時間打ち放題' });
                }
            }
            let azBest = getCheapestPlan(azUnitTotal, azPlans, reqHours);
            let azNote = azBest.isTimePlan ? `<span class="text-pink-400 font-bold text-xs">※${azBest.name}</span>` : `(1カゴ${azKagoPrice}円×${azKagoCount})`;
            if(isAzLadiesDay) azNote += `<br><span class="text-yellow-300 text-xs">★月水金レディースデー適用！</span>`;
            results.push({ id: 'azuchi_gc', name: '安土ゴルフクラブ', price: azBest.price, feature: '100球単位で明朗会計・バンカー無料', note: azNote, color: 'bg-amber-600' });

            // [リバーサイドジャンボゴルフ]
            let rjEntry = (time === 't6_9' || time === 't22_24' || isMember) ? 0 : 300;
            let rjBallPrice = isMember ? 9 : (isWeekend ? 10 : 9);
            if (isWeekday && time === 't9_12') rjBallPrice = 7;
            if (isFemale && day === 'mon_fri' && time !== 't6_9' && time !== 't22_24') rjBallPrice = 6;
            let rjUnitTotal = rjEntry + (rjBallPrice * balls);
            let rjNote = `(単価${rjBallPrice}円+入場料${rjEntry}円)`;
            if(isFemale && day === 'mon_fri') rjNote += `<br><span class="text-yellow-300 text-xs">★月金レディースデー適用！</span>`;
            results.push({ id: 'riverside_jumbo', name: 'リバーサイドジャンボ', price: rjUnitTotal, feature: '最高の芝とパター練習場', note: rjNote, color: 'bg-blue-600' });

            // [がれーじぱーく東近江]
            let gpTimePrice = reqHours === 1 ? 1000 : 2500; 
            let gpNoteTime = reqHours === 1 ? '1時間' : '3時間';
            results.push({ id: 'garage_park', name: 'がれーじぱーく', price: gpTimePrice, feature: '最新インドア・データ分析', note: `※${gpNoteTime}利用の目安`, color: 'bg-indigo-600' });

            // ランキング順にソートして描画
            results.sort((a, b) => a.price - b.price);

            let html = "";
            results.forEach((r, index) => {
                const rankIcon = index === 0 ? "🥇" : index === 1 ? "🥈" : "🥉";
                const priceStr = `¥${r.price.toLocaleString()}`;
                
                html += `
                <div class="flex items-center justify-between p-3 bg-slate-700 rounded-lg border border-slate-600 relative overflow-hidden">
                    <div class="absolute left-0 top-0 bottom-0 w-2 ${r.color}"></div>
                    <div class="pl-4">
                        <div class="flex items-center gap-2">
                            <span class="text-xl">${rankIcon}</span>
                            <span class="font-bold text-white text-md md:text-lg"><a href="#${r.id}" class="text-white hover:underline no-underline">${r.name}</a></span>
                        </div>
                        <p class="text-[10px] md:text-xs text-slate-400 mt-0.5">${r.feature}</p>
                        ${r.note ? `<p class="mt-0.5 text-xs text-slate-300 leading-tight">${r.note}</p>` : ''}
                    </div>
                    <div class="text-right pl-2 shrink-0">
                        <p class="text-[10px] md:text-xs text-slate-400">総額目安</p>
                        <p class="text-xl md:text-2xl font-black text-white">${priceStr}</p>
                    </div>
                </div>`;
            });

            resultsContainer.innerHTML = html;
        }

        // イベントリスナー登録
        if (userTypeSel) userTypeSel.addEventListener('change', calculateAll);
        if (daySel) daySel.addEventListener('change', calculateAll);
        if (timeSel) timeSel.addEventListener('change', calculateAll);
        Array.from(floorRadios).forEach(r => r.addEventListener('change', calculateAll));
        if (ballSlider) ballSlider.addEventListener('input', calculateAll);

        quickBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                if (ballSlider && e.target instanceof HTMLButtonElement) {
                    ballSlider.value = e.target.dataset.value || '100';
                    calculateAll();
                }
            });
        });

        // 初回実行
        calculateAll();
    });
    </script>
</BaseLayout>