---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

// --- 共通コンポーネント ---
import MySlider from '../../../components/MySlider.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import Sidebar from '../../../components/Sidebar.astro'; 

// --- この記事固有の情報 ---
const baseUrl = "https://shigagolf.com";
const articleUrl = `${baseUrl}/articles/comparison/omi-priceRank/`;
const publicationDate = "2025-10-03";
const lastModified = new Date();
const parentHub = {
    name: "近江八幡・東近江完全ガイド", 
    href: "/articles/omi-higashiomi-comparison/" 
};

// --- SEOコピー ---
const title = "【滋賀】打ちっぱなし料金比較！一番安い練習場はどこ？【シミュレーター付】(近江八幡・東近江)";
const description = "滋賀県（近江八幡・東近江）で一番安い打ちっぱなしはどこ？グリーンピア、さくらゴルフ、安土など全5施設の複雑な料金システム（単価・打ち放題・入場料・レディースデー）を徹底比較。あなたに最適な最安施設が1秒でわかる「料金比較シミュレーター」搭載！";
const headline = "近江八幡・東近江で一番安い打ちっぱなしは？最強の料金比較シミュレーター";
const category = "比較記事"; 
const imageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (2).jpg";

// --- Firebaseから各練習場の情報を取得 ---
const rangeIds = ['azuchi_gc', 'greenpia_oh', 'sakura_gc', 'riverside_jumbo', 'garage_park'];
const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const rangePromises = rangeIds.map(id => getDoc(doc(db, `artifacts/${appId}/public/data/practice_ranges/${id}`)));
const rangeDocs = await Promise.all(rangePromises);

const rangesData = rangeDocs.reduce((acc, docSnap, index) => {
    if (docSnap.exists()) { acc[rangeIds[index]] = docSnap.data(); }
    else { acc[rangeIds[index]] = null; }
    return acc;
}, {});

if (rangesData.greenpia_oh) {
    rangesData.greenpia_oh.name = "グリーンピア近江八幡ゴルフ";
}

// --- 各施設の追加情報（JSON-LD・比較表用） ---
const additionalData = {
    azuchi_gc: {
        parking: '約40台',
        access: 'JR安土駅から車で5分',
        environment: '昔ながらの雰囲気。駐車場も停めやすい。',
        reviewUrl: '/articles/azuchi-review/',
        reviewText: 'プリペイドカード不要で、現金で気軽に練習できるのが最大の魅力。<br/>アットホームな雰囲気で、ゴルフ練習場デビューに最適。駐車場も広く停めやすいです。バンカー練習場も無料で利用できます。',
        altFull: '安土ゴルフクラブの打席からネット方向を見た全景',
        altDetail: '安土ゴルフクラブの700円券売機',
        priceBase: { type: 'ball', admission: 0, price: 700, balls: 100 }
    },
    greenpia_oh: {
        parking: '約80台',
        access: '名神竜王ICから車で10分',
        environment: '<strong>道中が狭く、運転に注意</strong>',
        reviewUrl: '/articles/review/greenpia-oh/',
        reviewText: '施設の古さはあるものの、それを補って余りある価格設定が特徴。<br/>特に平日日中の料金や、SDカード割引を組み合わせることで、驚異的な安さを実現します。駐車場は広いですが、<strong>練習場へ至る道中が狭いので運転に自信がない方はご注意ください。</strong>',
        altFull: 'グリーンピア近江八幡ゴルフの広々とした練習スペース',
        altDetail: 'グリーンピア近江八幡ゴルフの2階打席からの眺め',
        priceBase: { type: 'ball', admission: 300, ballPrice: 5, balls: 100 }
    },
    sakura_gc: {
        parking: '約50台',
        access: '名神竜王ICから車で15分',
        environment: '冷房が快適。一部駐車しにくい箇所有',
        reviewUrl: '/articles/sakura-gc-review/',
        reviewText: '女性やジュニアへの特典が非常に手厚く、対象者にとっては最高の練習環境です。<br/>夏場は冷房が強く快適。広々としたアプローチ練習場や初心者優先打席など、幅広い層に配慮されていますが、<strong>駐車場の一部はポールがあり停めにくい場合があります。</strong>',
        altFull: 'さくらゴルフ倶楽部の清潔感のある打席エリア',
        altDetail: 'さくらゴルフ倶楽部の充実したアプローチ練習グリーン',
        priceBase: { type: 'ball', admission: 280, ballPrice: 7, balls: 100 }
    },
    riverside_jumbo: {
        parking: '約40台',
        access: '名神八日市ICから車で10分',
        environment: '打席リニューアルで快適。駐車場も停めやすい。',
        reviewUrl: '/articles/review/riverside-jumbo/',
        reviewText: '「安さ」よりも「質」を求めるゴルファーが集う練習場。<br/>無料で使える本格的なパターグリーンや、質の高いアプローチ練習場はスコアアップへの投資価値があります。2025年6月に打席周りがリニューアルされ、夏場はミストも出るなど、快適性も向上しています。',
        altFull: 'リバーサイドジャンボゴルフの広大なフェアウェイ',
        altDetail: 'リバーサイドジャンボゴルフの無料で使えるパターグリーン',
        priceBase: { type: 'ball', admission: 400, ballPrice: 8, balls: 100 }
    },
    garage_park: {
        parking: '約20台',
        access: '蒲生スマートICから車で2分',
        environment: 'インドアで快適。IC直結でアクセス◎',
        reviewUrl: '/articles/garege-park-review/',
        reviewText: '蒲生スマートICから2分とアクセス抜群。<br/>天候を気にせず、データに基づいて効率的に練習したい方向け。月額5,000円のフリーパスは、練習頻度が高い人にとって最高の選択肢です。駐車場も施設前で停めやすいです。',
        altFull: 'がれーじぱーく東近江のインドア練習ブース',
        altDetail: 'がれーじぱーく東近江に設置された弾道測定器の画面',
        priceBase: { type: 'time', price: 1000 }
    }
};

// --- 写真URL ---
const images = {
    azuchi_gc: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8076 2.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8069 2.png" },
    greenpia_oh: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/IMG_6879.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/名称未設定.png" },
    rose_gc: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_9787.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_6020.jpg" }, // 後方互換性のため維持
    sakura_gc: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_9787.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_6020.jpg" },
    riverside_jumbo: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_6450 2.jpg", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_9009.png" },
    garage_park: { full: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/IMG_9502.png", detail: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/シガゴル.jpg" }
};

// --- 構造化データ用の画像URL ---
const structuredDataImages = {
    garage_park: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/0000range.png",
    greenpia_oh: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/IMG_6751.png",
    riverside_jumbo: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_6453.jpg",
    sakura_gc: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/0000000img.jpg",
    azuchi_gc: "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8067 2.png"
};

// --- 総合比較表のデータ ---
const overallSummaryData = rangeIds.map(id => {
    const range = rangesData[id];
    let bays_yards = '-';
    if (range) {
        if (id === 'garage_park') {
            bays_yards = `${range.bays || 1}席/インドア`;
        } else {
            bays_yards = `${range.bays || '-'}席/${range.yardage || '-'}yd`;
        }
    }
    return {
        id,
        name: range?.name || '練習場名',
        city: range?.city || '',
        bays_yards,
        parking: additionalData?.[id]?.parking || '-',
        price_type: id === 'garage_park' ? '<strong>時間制</strong>' : '球貸し',
        all_you_can_hit: id === 'riverside_jumbo' ? '<strong>なし</strong>' : '<strong>◯</strong>',
        feature: additionalData?.[id]?.environment || '-'
    };
});

// --- 動的価格帯計算関数（JSON-LD用） ---
const calculatePriceRange = (id) => {
    const data = additionalData?.[id]?.priceBase;
    if (!data) return "¥1000-¥3000"; 
    if (data.type === 'time') {
        const lower = data.price;
        return `¥${lower}-¥${lower * 2}`;
    }
    if (data.type === 'ball') {
        const lower = (data.admission || 0) + (data.price ? data.price : (data.ballPrice * data.balls));
        const upper = (data.admission || 0) + (data.price ? data.price * 2.5 : (data.ballPrice * data.balls * 2.5));
        return `¥${Math.floor(lower)}-¥${Math.floor(upper)}`;
    }
    return "¥1000-¥3000";
};

// --- JSON-LD用リスト要素の構築 ---
const itemListElements = rangeIds.map((id, index) => {
    const range = rangesData[id];
    if (!range) return null;
    return {
        "@type": "ListItem",
        "position": index + 1,
        "item": {
            "@type": "SportsActivityLocation",
            "name": range.name,
            "url": `${baseUrl}/ranges/${id}/`,
            "image": [structuredDataImages[id]],
            "telephone": range.phone,
            "priceRange": calculatePriceRange(id),
            "address": {
                "@type": "PostalAddress",
                "streetAddress": range.address,
                "addressLocality": range.city,
                "addressRegion": "滋賀県",
                "postalCode": range.postalCode,
                "addressCountry": "JP"
            }
        }
    };
}).filter(Boolean);

const faqElements = {
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": "初心者におすすめのゴルフ練習場はどこですか？", "acceptedAnswer": { "@type": "Answer", "text": "近江八幡市・東近江市では「安土ゴルフクラブ」と「さくらゴルフ倶楽部」が特におすすめです。安土ゴルフクラブは料金が分かりやすくアットホームな雰囲気で、さくらゴルフ倶楽部には初心者優先スペースがあり周りの目を気にせず練習に集中できます。" } },
        { "@type": "Question", "name": "一番安いゴルフ練習場（打ちっぱなし）はどこですか？", "acceptedAnswer": { "@type": "Answer", "text": "料金はプランや時間帯によって大きく異なりますが、特定の割引（SDカード等）が適用されるなら「グリーンピア近江八幡ゴルフ」が1球あたりの単価が最も安くなる可能性があります。女性やジュニアの方であれば、「さくらゴルフ倶楽部」の特典が非常にお得です。" } }
    ]
};

// --- 関連記事リスト ---
const experienceReports = [
    { url: '/articles/azuchi-review/', title: '安土ゴルフクラブ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/0000image0000.png' },
    { url: '/articles/sakura-gc-review/', title: 'さくらゴルフ倶楽部 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/00000ai.png' },
    { url: '/articles/garege-park-review/', title: 'がれーじぱーく東近江 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/00000ai.jpg' },
    { url: '/articles/review/greenpia-oh/', title: 'グリーンピア近江八幡ゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/シガゴル (14).jpg' },
    { url: '/articles/review/riverside-jumbo/', title: 'リバーサイドジャンボゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/シガゴル (15).jpg' },
];
const comparisonArticles = [
    { url: '/articles/omi-higashiomi-approach/', title: '【アプローチ＆バンカー練習場】近江八幡・東近江5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/approach.jpg' },
    { url: '/articles/comparison/omi-putting/', title: '【パター練習場が充実】近江八幡・東近江エリア5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル.jpg' },
    { url: '/articles/comparison/omi-lesson/', title: '【レッスン比較】近江八幡・東近江の初心者向け4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (12).jpg' },
    { url: '/articles/omi-higashiomi-comparison/', title: '【総合比較】近江八幡・東近江エリアの完全ガイド', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/ナイスミス (9).png' },
];

const gmapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<BaseLayout title={title} description={description} pubDate={publicationDate} ogImage={imageUrl} parentHub={parentHub}>
    
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
        "headline": headline, 
        "description": description, 
        "image": [
            imageUrl,
            images.azuchi_gc.full,
            images.azuchi_gc.detail,
            images.greenpia_oh.full,
            images.greenpia_oh.detail,
            images.sakura_gc.full,
            images.sakura_gc.detail,
            images.riverside_jumbo.full,
            images.riverside_jumbo.detail,
            images.garage_park.full,
            images.garage_park.detail
        ],
        "author": { "@type": "Person", "name": "関（シガゴル運営者）", "url": `${baseUrl}/about/` },
        "publisher": { "@type": "Organization", "name": "シガゴル", "logo": { "@type": "ImageObject", "url": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/logo.png" }},
        "datePublished": new Date(publicationDate).toISOString(), 
        "dateModified": lastModified.toISOString(),
        "mainEntity": [
            { "@type": "ItemList", "name": "近江八幡・東近江のゴルフ練習場（打ちっぱなし）比較", "itemListElement": itemListElements },
            faqElements
        ]
    })} />

     <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col lg:flex-row gap-8 items-stretch my-8">

        {/* ▼ 左側のメイン記事エリア ▼ */}
        <main id="article-view" class="w-full lg:flex-1 bg-white p-6 md:p-8 rounded-lg shadow-lg text-slate-700 leading-relaxed overflow-hidden">

            <a href="/articles/omi-higashiomi-comparison/" class="nav-link back-button mb-6 inline-block text-green-700 font-semibold hover:underline">
                ‹ 近江八幡・東近江エリア完全ガイドに戻る
            </a>
            
            <style is:global>
