---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

// --- 共通コンポーネント ---
import MySlider from '../../../components/MySlider.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import VoiceBox from '../../../components/VoiceBox.astro'; // VoiceBoxコンポーネントをインポート
import Sidebar from '../../../components/Sidebar.astro'; 

// --- この記事固有の情報 ---
const baseUrl = "https://shigolf.com";
const articleUrl = `${baseUrl}/articles/comparison/o-mihachiman-guide/`;
const publicationDate = "2025-10-17"; // 元の公開日を維持
const lastModified = new Date(); // 最終更新日を自動取得

// ★★★ SEOコピーを「対決」型に全面変更 ★★★
const title = "【近江八幡 打ちっぱなし】グリーンピア vs 安土 結局どっち？料金・質・アクセスを現地ライターが本音で徹底比較 | シガゴル";
const description = "近江八幡の打ちっぱなし「グリーンピア VS 安土ゴルフ」結局どっち？SDカードの安さ、アクセスの悪さ、客層、マットの質まで、現地ライターが本音で結論を出します。";
const category = "比較記事";
const headline = "【近江八幡 打ちっぱなし】グリーンピア vs 安土ゴルフクラブ 結局どっち？料金・質・アクセスを現地ライターが本音で徹底比較！";
const imageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/hachiman-guide.jpg"; // ★対決を煽るアイキャッチに変更推奨 (これは仮のURLです)

// --- Firebaseから各練習場の情報を取得 ---
const rangeIds = ['greenpia_oh', 'azuchi_gc', 'elgrace_omihachiman'];
const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const rangePromises = rangeIds.map(id => getDoc(doc(db, `artifacts/${appId}/public/data/practice_ranges/${id}`)));
const rangeDocs = await Promise.all(rangePromises);

const rangesData = rangeDocs.reduce((acc, docSnap, index) => {
    if (docSnap.exists()) { acc[rangeIds[index]] = docSnap.data(); }
    else { acc[rangeIds[index]] = null; }
    return acc;
}, {});

// --- データの手動修正 ---
if (rangesData.greenpia_oh) {
  	rangesData.greenpia_oh.name = "グリーンピア近江八幡ゴルフ";
}
if (rangesData.azuchi_gc && !rangesData.azuchi_gc.access) {
    rangesData.azuchi_gc.access = 'JR安土駅から車で5分';
}

// --- 各施設の追加情報 (体験レポートのURL) ---
const additionalData = {
  	azuchi_gc: { reviewUrl: '/articles/azuchi-review/' },
    greenpia_oh: { reviewUrl: '/articles/review/greenpia-oh/' },
    elgrace_omihachiman: { reviewUrl: null }
};

// --- JSON-LD構造化データ (FAQを対決型に修正) ---
const mainEntity = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
    "headline": headline, "description": description,
    "image": [ imageUrl, "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/IMG_6879.png", "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8076 2.png" ],
    "author": { "@type": "Person", "name": "関（シガゴル運営者）", "url": `${baseUrl}/about/` },
    "publisher": { "@type": "Organization", "name": "シガゴル", "logo": { "@type": "ImageObject", "url": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/logo.png" }},
    "datePublished": new Date(publicationDate).toISOString(), "dateModified": lastModified.toISOString()
};

// ★★★ FAQを「検索意図」に最適化 ★★★
const faqElements = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": articleUrl + "#faq",
  "mainEntity": [
    { "@type": "Question", "name": "近江八幡で「グリーンピア」と「安土」結局どっちが安いの？", "acceptedAnswer": { "@type": "Answer", "text": "【結論】SDカード（セーフドライバーカード）等割引があるなら「グリーンピア」、ビジター（割引なし）なら「安土ゴルフクラブ」が安くなります。安土は入場料無料で100球700円とシンプル。グリーンピアは平日2Fなら1球5円ですが、SDカード提示で1球3円という驚異的な安さになります。" } },
    { "@type": "Question", "name": "近江八幡市で初心者におすすめのゴルフ練習場は？", "acceptedAnswer": { "@type": "Answer", "text": "手軽さ・快適さ・アクセスの良さを重視するなら「安土ゴルフクラブ」がおすすめです。現金払いのシンプルな料金体系で、練習場の雰囲気も落ち着いているため、初めての方でも安心して利用できます。" } },
    { "@type": "Question", "name": "近江八幡でアプローチ練習ができるのはどこ？", "acceptedAnswer": { "@type": "Answer", "text": "「グリーンピア近江八幡ゴルフ」はアプローチ練習場・バンカー・パタースペースが揃っています。「安土ゴルフクラブ」は無料のバンカー練習場が利用可能です。" } }
  ]
};

// --- 関連記事リスト ---
const experienceReports = [
    { url: '/articles/azuchi-review/', title: '安土ゴルフクラブ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/0000image0000.png' },
    { url: '/articles/sakura-gc-review/', title: 'さくらゴルフ倶楽部 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/00000ai.png' },
    { url: '/articles/garege-park-review/', title: 'がれーじぱーく東近江 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/garage_park/gallery/00000ai.jpg' },
    { url: '/articles/review/greenpia-oh/', title: 'グリーンピア近江八幡ゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/シガゴル (14).jpg' },
    { url: '/articles/review/riverside-jumbo/', title: 'リバーサイドジャンボゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/シガゴル (15).jpg' },
];
const comparisonArticles = [
    { url: '/articles/comparison/omi-pricerank/', title: '【料金で徹底比較】近江八幡・東近江の安い練習場5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (2).jpg' },
    { url: '/articles/omi-higashiomi-approach/', title: '【アプローチ＆バンカー練習場】近江八幡・東近江5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/approach.jpg' },
    { url: '/articles/comparison/omi-putting/', title: '【パター練習場が充実】近江八幡・東近江エリア5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル.jpg' },
    { url: '/articles/comparison/omi-lesson/', title: '【レッスン比較】近江八幡・東近江の初心者向け4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (12).jpg' },
    { url: '/articles/comparison/higashiomi-guide/', title: '【2025年最新】東近江市のゴルフ練習場まとめ｜全3施設を料金・設備で徹底比較', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (14).jpg' },
    { url: '/articles/comparison/o-mihachiman-guide/', title: '【2025年最新】近江八幡市のゴルフ練習場まとめ｜全3施設を料金・設備で徹底比較', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (14)のコピー.jpg' },
    { url: '/articles/comparison/omi-higashiomi-comparison/', title: '【総合比較】近江八幡・東近江エリアのゴルフ練習場4選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/ナイスミス (9).png' },
];

const gmapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<BaseLayout title={title} description={description} pubDate={publicationDate} ogImage={imageUrl}>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(mainEntity)} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqElements)} />

     <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col lg:flex-row gap-8 items-stretch my-8">

        

        {/* ▼ 左側のメイン記事エリア ▼ */}

        <main id="article-view" class="w-full lg:flex-1 bg-white p-6 md:p-8 rounded-lg shadow-lg text-slate-700 leading-relaxed overflow-hidden">

            

            <a href="/articles/" class="nav-link back-button mb-6 inline-block text-green-700 font-semibold hover:underline">

                ‹ お役立ち記事一覧に戻る

            </a>
            
            <style is:global>
              html { scroll-behavior: smooth; }
              section[id] { scroll-margin-top: 80px; }
              .cta-icon { width: 1.2em; height: 1.2em; margin-right: 0.5em; vertical-align: text-bottom; }
              .table-wrapper { overflow-x: auto; }
              .min-w-table-pc { min-width: 600px; }
              .table-wrapper th:first-child, .table-wrapper td:first-child { position: -webkit-sticky; position: sticky; left: 0; z-index: 10; }
              .table-wrapper thead th:first-child { background-color: #f1f5f9; }
              .table-wrapper tbody tr.bg-white td:first-child { background-color: #ffffff; }
              .table-wrapper tbody tr.bg-slate-50 td:first-child { background-color: #f8fafc; }
            
              @media (max-width: 767px) and (orientation: portrait) {
                #article-view .responsive-table { min-width: 100% !important; }
                #article-view .responsive-table thead { display: none !important; }
                #article-view .responsive-table tr { display: block !important; margin-bottom: 1.5rem !important; border: 1px solid #cbd5e1 !important; border-radius: 0.5rem !important; box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1) !important; overflow: hidden; }
                #article-view .responsive-table td { display: block !important; text-align: right !important; position: relative !important; border-bottom: 1px solid #e2e8f0 !important; padding: 0.75rem 0.75rem 0.75rem 130px !important; left: auto !important; background-color: #fff !important; }
                #article-view .responsive-table td:last-child { border-bottom: none !important; }
                #article-view .responsive-table td::before { content: attr(data-label); position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); font-weight: 600; text-align: left; color: #475569; width: 110px; }
                #article-view .responsive-table td:first-child { background-color: #f1f5f9 !important; font-weight: bold !important; text-align: center !important; padding-left: 0.75rem !important; }
                
                /* ★★★ エラー修正 ('') ★★★ */
                #article-view .responsive-table td:first-child::before { content: '' !important; }
                
                #article-view .show-table-view.table-wrapper { overflow-x: auto !important; }
                #article-view .show-table-view .responsive-table { min-width: 600px !important; }
                #article-view .show-table-view .responsive-table thead { display: table-header-group !important; }
                #article-view .show-table-view .responsive-table tr { display: table-row !important; border: none !important; box-shadow: none !important; }
                #article-view .show-table-view .responsive-table td { display: table-cell !important; border: 1px solid #cbd5e1 !important; padding: 0.5rem !important; position: static !important; text-align: center !important; }
                #article-view .show-table-view .responsive-table td:first-child { text-align: left !important; position: sticky !important; left: 0 !important; }
                #article-view .show-table-view .responsive-table td::before { content: none !important; }
                #article-view .show-table-view tr.bg-slate-50 td { background-color: #f8fafc !important; }
                #article-view .show-table-view tr.bg-white td { background-color: #fff !important; }
                #article-view .show-table-view thead th { background-color: #f1f5f9 !important; }
              }
            </style>
            
            <header>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-800">{headline}</h1>
                <p class="text-sm text-slate-500 mt-2">最終更新日：{lastModified.getFullYear()}-{String(lastModified.getMonth() + 1).padStart(2, '0')}-{String(lastModified.getDate()).padStart(2, '0')}</p>
            </header>

            <Image src={imageUrl} alt="近江八幡市のゴルフ練習場「グリーンピア」と「安土ゴルフクラブ」の対決" class="w-full h-auto object-cover rounded-lg my-6" loading="eager" width={1200} height={675} fetchpriority="high" decoding="async" format="webp" quality={80} />
            
            <p>近江八幡市で打ちっぱなし練習場を探すとき、多くのゴルファーが「<strong>グリーンピアと安土ゴルフ、結局どっちがいいの？</strong>」という疑問にぶつかります。</p>
            <p>SDカード提示で1球3円という激安の「グリーンピア近江八幡ゴルフ」か。<br/>それとも、入場料なし・現金700円ポッキリの手軽さを誇る「安土ゴルフクラブ」か。</p>
            <p>はじめまして、「シガゴル」運営者の関（<a href="/about/">@seki</a>）です。私自身が両方の練習場を使い倒した上で、その永遠の疑問に終止符を打ちます。</p>
            <p>この記事では、料金の安さだけでなく、アクセスのストレス、客層（マナー）、打席マットの質といった「<strong>実際に行かないと分からない本音</strong>」で、あなたに最適な練習場を結論付けます。</p>

            <div class="not-prose bg-green-50 border border-l-4 border-green-500 p-4 rounded-lg my-6">
              <h4 class="text-lg font-bold text-green-800 mb-2 mt-0">【結論】あなたはどっちを選ぶべき？</h4>
              <ul class="list-disc list-inside text-slate-700 m-0 p-0">
                <li class="mb-1"><strong>安さ最優先（SDカード等所持）</strong>なら → <a href="#greenpia_oh-info" class="text-green-700 hover:underline font-semibold">グリーンピア近江八幡ゴルフ</a></li>
                <li class="mb-1"><strong>手軽さ・快適さ・アクセスの良さ</strong>を求めるなら → <a href="#azuchi_gc-info" class="text-green-700 hover:underline font-semibold">安土ゴルフクラブ</a></li>
                <li class="mb-1"><strong>女性・ジュニア</strong>で打ち放題がしたいなら → <a href="#greenpia_oh-info" class="text-green-700 hover:underline font-semibold">グリーンピア近江八幡ゴルフ</a></li>
                <li><strong>弾道測定器</strong>で分析・レッスンしたいなら → <a href="#elgrace_omihachiman-info" class="text-green-700 hover:underline font-semibold">ELGRACE 近江八幡（番外編）</a></li>
              </ul>
            </div>

            <div class="toc-container bg-slate-50 p-6 rounded-lg border border-slate-200 my-8 not-prose">
                <h2 class="text-xl font-bold mb-4 text-slate-800">この記事の目次</h2>
                <ul class="space-y-2 list-disc list-inside">
                    <li><a href="#summary-table" class="text-green-700 hover:underline">【総合比較】近江八幡市の練習場3施設</a></li>
                    <li><a href="#vs-battle" class="text-green-700 hover:underline">【徹底比較】グリーンピア vs 安土 5番勝負</a></li>
                    <li><a href="#vs-1-price" class="text-green-700 hover:underline ml-4">① 料金対決</a></li>
                    <li><a href="#vs-2-access" class="text-green-700 hover:underline ml-4">② アクセス（ストレス）対決</a></li>
                    <li><a href="#vs-3-comfort" class="text-green-700 hover:underline ml-4">③ 快適さ（客層・環境）対決</a></li>
                    <li><a href="#vs-4-facility" class="text-green-700 hover:underline ml-4">④ 設備（マット）対決</a></li>
                    <li><a href="#vs-5-shortgame" class="text-green-700 hover:underline ml-4">⑤ ショートゲーム対決</a></li>
                    <li><a href="#conclusion" class="text-green-700 hover:underline">【結論】私が「安土ゴルフクラブ」を選ぶ理由</a></li>
                    <li><a href="#extra-elgrace" class="text-green-700 hover:underline">【番外編】弾道測定器ならELGRACE近江八幡</a></li>
                    <li><a href="#info-summary" class="text-green-700 hover:underline">各施設の基本情報まとめ</a></li>
                </ul>
            </div>

            <section id="summary-table">
                <h2 class="text-2xl font-bold mt-8 pt-4 border-t border-slate-200">【総合比較】近江八幡市のゴルフ練習場3施設</h2>
                <p>まずは全体像から。3つの施設は「打ちっぱなし（2施設）」と「会員制インドア（1施設）」で特徴が大きく異なります。</p>
                 <div class="not-prose my-4 text-center">
                    <button class="view-toggle-btn md:hidden inline-flex items-center justify-center bg-slate-600 text-white font-semibold py-2 px-4 rounded-lg shadow hover:bg-slate-700 transition-colors duration-200 text-sm" data-target-id="summary-table-container">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path></svg>
                        画面を横にして一覧表で見る
                    </button>
                 </div>
                 <div id="summary-table-container" class="table-wrapper my-4 not-prose">
                    <table class="w-full text-sm text-left border border-slate-300 min-w-table-pc responsive-table">
                        <thead class="bg-slate-100">
                            <tr>
                                <th class="px-4 py-3 border border-slate-300 align-middle text-center whitespace-nowrap">練習場名</th>
                                <th class="px-4 py-3 border border-slate-300 align-middle text-center whitespace-nowrap">カテゴリ</th>
                                <th class="px-4 py-3 border border-slate-300 align-middle text-center whitespace-nowrap">料金体系</th>
                                <th class="px-4 py-3 border border-slate-300 text-center whitespace-nowrap">打席/ヤード</th>
                                <th class="px-4 py-3 border border-slate-300 text-center">特徴</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="bg-white">
                                <td data-label="練習場名" class="px-4 py-2 border align-middle font-semibold whitespace-nowrap"><a href="#greenpia_oh-info" class="text-blue-600 hover:underline">グリーンピア近江八幡ゴルフ</a></td>
                                <td data-label="カテゴリ" class="px-4 py-2 border text-center align-middle whitespace-nowrap">打ちっぱなし</td>
                                <td data-label="料金体系" class="px-4 py-2 border text-center align-middle">球貸し</td>
                                <td data-label="打席/ヤード" class="px-4 py-2 border text-center align-middle whitespace-nowrap">{rangesData.greenpia_oh?.bays || '-'}席 / {rangesData.greenpia_oh?.yardage || '-'}yd</td>
                                <td data-label="特徴" class="px-4 py-2 border align-middle text-xs">SDカード等割引で激安。女性もお得。</td>
                            </tr>
                            <tr class="bg-slate-50">
                                <td data-label="練習場名" class="px-4 py-2 border align-middle font-semibold whitespace-nowrap"><a href="#azuchi_gc-info" class="text-blue-600 hover:underline">安土ゴルフクラブ</a></td>
                                <td data-label="カテゴリ" class="px-4 py-2 border text-center align-middle whitespace-nowrap">打ちっぱなし</td>
                                <td data-label="料金体系" class="px-4 py-2 border text-center align-middle">球貸し (現金)</td>
                                <td data-label="打席/ヤード" class="px-4 py-2 border text-center align-middle whitespace-nowrap">{rangesData.azuchi_gc?.bays || '-'}席 / {rangesData.azuchi_gc?.yardage || '-'}yd</td>
                                <td data-label="特徴" class="px-4 py-2 border align-middle text-xs">入場料無料・700円ポッキリで手軽。</td>
                            </tr>
                            <tr class="bg-white">
                                <td data-label="練習場名" class="px-4 py-2 border align-middle font-semibold whitespace-nowrap"><a href="#elgrace_omihachiman-info" class="text-blue-600 hover:underline">ELGRACE 近江八幡</a></td>
                                <td data-label="カテゴリ" class="px-4 py-2 border text-center align-middle whitespace-nowrap"><strong>会員制インドア</strong></td>
                                <td data-label="料金体系" class="px-4 py-2 border text-center align-middle">月額制</td>
