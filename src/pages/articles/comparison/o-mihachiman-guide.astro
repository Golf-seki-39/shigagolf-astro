                    <figure>
                        <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/IMG_8118 2.png" alt="安土ゴルフクラブの無料バンカー" class="w-full h-auto object-cover rounded-lg" loading="lazy" width={1200} height={900} decoding="async" format="webp" quality={80} />
                        <figcaption class="text-center text-sm text-slate-500 mt-2">安土の無料バンカー。砂も入っており「案外使える」レベルです。</figcaption>
                    </figure>
                </div>

                 <div class="grid md:grid-cols-2 gap-4 not-prose mt-4">
                    <figure>
                        <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/IMG_6858.png" alt="グリーンピアのアプローチ練習場" class="w-full h-auto object-cover rounded-lg" loading="lazy" width={1200} height={900} decoding="async" format="webp" quality={80} />
