                                    </a>
                                    {additionalData[id]?.reviewUrl && (
                                        <a href={additionalData[id].reviewUrl} class="nav-link inline-flex items-center justify-center bg-orange-500 text-white font-bold py-3 px-6 rounded-lg shadow-md hover:bg-orange-600 transition-colors duration-200 text-base no-underline">
                                            <svg class="cta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4a4 4 0 1 1 0 8a4 4 0 0 1 0-8Zm0 10c2.67 0 8 1.34 8 4v2H4v-2c0-2.66 5.33-4 8-4Z"></path></svg>
                                            管理人の詳細体験レポートを読む
                                        </a>
                                    )}
                                </div>
                             </div>
                         )
                     })}
                 </div>
            </section>
        </article>
        </main> {/* ← メイン記事エリアを閉じる */}

        {/* ▼ 右側のサイドバーを呼び出す ▼ */}
        <Sidebar />
        
    </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggleButtons = document.querySelectorAll('.view-toggle-btn');
        
        toggleButtons.forEach(button => {
          button.addEventListener('click', () => {
            const targetId = button.dataset.targetId;
            const tableContainer = document.getElementById(targetId);

            if (!tableContainer) return;

            tableContainer.classList.toggle('show-table-view');

            const isTableView = tableContainer.classList.contains('show-table-view');
            if (isTableView) {
              button.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M4 3a1 1 0 00-1 1v12a1 1 0 001 1h12a1 1 0 001-1V4a1 1 0 00-1-1H4zm3 2h6v4H7V5zm0 6h6v2H7v-2z" />
                </svg>
                カード表示に戻す`;
            } else {
              button.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                </svg>
                画面を横にして一覧表で見る`;
            }
          });
        });
      });
    </script>
</BaseLayout>