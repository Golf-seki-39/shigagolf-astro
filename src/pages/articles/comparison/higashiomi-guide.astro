---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db } from "../../../lib/firebase.js";
import { doc, getDoc } from "firebase/firestore";
import { Image } from "astro:assets";

import MySlider from '../../../components/MySlider.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import Sidebar from '../../../components/Sidebar.astro'; 

// --- この記事固有の情報 ---
const baseUrl = "https://shigagolf.com";
const articleUrl = `${baseUrl}/articles/comparison/higashiomi-guide/`;
const publicationDate = "2026-06-23";
const lastModified = new Date();
const parentHub = {
    name: "近江八幡・東近江完全ガイド", 
    href: "/articles/omi-higashiomi-hub/" 
};

// --- SEOコピー ---
const title = "【東近江 打ちっぱなし】ジャンボ vs さくらゴルフ 結局どっち？現地ライターが本音で徹底比較 | シガゴル";
const description = "滋賀県東近江市の2大ゴルフ練習場「リバーサイドジャンボゴルフ」と「さくらゴルフ倶楽部」を現地ライターが徹底比較！料金シミュレーター付き。パター・バンカーの質、駐車場の停めやすさ、初心者に嬉しい設備など、リアルな本音であなたに合う施設を判定します。";
const headline = "【東近江 打ちっぱなし】ジャンボ vs さくらゴルフ 結局どっち？現地ライターが本音で徹底比較！";
const category = "比較記事"; 
// ★いただいたオリジナルのアイキャッチ画像に変更
const imageUrl = "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/higashiomi-guide.jpg";

// --- 関連記事リスト ---
const experienceReports = [
    { url: '/articles/sakura-gc-review/', title: 'さくらゴルフ倶楽部 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/00000ai.png' },
    { url: '/articles/review/riverside-jumbo/', title: 'リバーサイドジャンボゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/シガゴル (15).jpg' },
    { url: '/articles/azuchi-review/', title: '安土ゴルフクラブ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/azuchi_gc/gallery/0000image0000.png' },
    { url: '/articles/review/greenpia-oh/', title: 'グリーンピア近江八幡ゴルフ 体験レポート', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/greenpia_oh/gallery/シガゴル (14).jpg' },
];
const comparisonArticles = [
    { url: '/articles/comparison/omi-pricerank/', title: '【料金で徹底比較】近江八幡・東近江の安い練習場5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/シガゴル (2).jpg' },
    { url: '/articles/omi-higashiomi-approach/', title: '【アプローチ＆バンカー練習場】近江八幡・東近江5選', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/approach.jpg' },
    { url: '/articles/comparison/o-mihachiman-guide/', title: '【近江八幡】グリーンピア vs 安土 結局どっち？', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/hachiman-guide.jpg' },
    { url: '/articles/omi-higashiomi-hub/', title: '【総合比較】近江八幡・東近江エリアの完全ガイド', img: 'https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/ナイスミス (9).png' },
];

// --- JSON-LD構造化データ（SEO対策） ---
const mainEntity = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
    "headline": headline,
    "description": description,
    "image": [
        imageUrl,
        "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_6450 2.jpg",
        "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/IMG_9787.png"
    ],
    "author": { "@type": "Person", "name": "関（シガゴル運営者）", "url": `${baseUrl}/about/` },
    "publisher": {
        "@type": "Organization",
        "name": "シガゴル",
        "logo": { "@type": "ImageObject", "url": "https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/image_archive/gallery/logo.png" }
    },
    "datePublished": new Date(publicationDate).toISOString(),
    "dateModified": lastModified.toISOString()
};

const faqElements = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "東近江市でパターやバンカーの練習に最適なのは「ジャンボ」と「さくら」どっち？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "ショートゲームの質を求めるなら「リバーサイドジャンボゴルフ」が圧倒的におすすめです。広大な無料パターグリーンと、アゴの高い本格的なバンカーを備えており、東近江エリアで最高クラスの環境が整っています。"
            }
        },
        {
            "@type": "Question",
            "name": "女性や初心者が安く練習できるのはどっち？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "圧倒的に「さくらゴルフ倶楽部」がおすすめです。女性とジュニアは入場料無料で、1時間515円からの打ち放題が利用できます。さらに2階には周囲の視線が気にならない「初心者優先スペース」も完備されています。"
            }
        },
        {
            "@type": "Question",
            "name": "ジャンボとさくら、駐車場の停めやすさに違いはある？",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "ジャンボは駐車枠が広くゆったり停められます。一方さくらは、駐車場内に街灯のポールがあるため、混雑時にセダンやSUVなどの前が長い車を停める際は少し切り返しに気をつかう場合があります。"
            }
        }
    ]
};

// --- Firebaseから練習場データを取得（基本情報用） ---
const rangeIds = ['riverside_jumbo', 'sakura_gc'];
const appId = import.meta.env.PUBLIC_FIREBASE_APP_ID;
const rangePromises = rangeIds.map(id => getDoc(doc(db, `artifacts/${appId}/public/data/practice_ranges/${id}`)));
const rangeDocs = await Promise.all(rangePromises);

const rangesData = rangeDocs.reduce((acc, docSnap, index) => {
    if (docSnap.exists()) { acc[rangeIds[index]] = docSnap.data(); }
    else { acc[rangeIds[index]] = null; }
    return acc;
}, {});
---

<BaseLayout title={title} description={description} pubDate={publicationDate} ogImage={imageUrl} parentHub={parentHub}>
    
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(mainEntity)} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqElements)} />

     <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col lg:flex-row gap-8 items-stretch my-8">

        {/* ▼ 左側のメイン記事エリア ▼ */}
        <main id="article-view" class="w-full lg:flex-1 bg-white p-6 md:p-8 rounded-lg shadow-lg text-slate-700 leading-relaxed overflow-hidden">

            <a href="/articles/omi-higashiomi-hub/" class="nav-link back-button mb-6 inline-block text-green-700 font-semibold hover:underline">
                ‹ 近江八幡・東近江エリア完全ガイドに戻る
            </a>
            
            <style is:global>
              html { scroll-behavior: smooth; }
              section[id], h2[id], h3[id] { scroll-margin-top: 80px; }
            </style>
            
            <article class="prose lg:prose-xl max-w-none">

            <header>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-800 leading-tight">{headline}</h1>
                <p class="text-sm text-slate-500 mt-2 mb-6">
                    最終更新日：{lastModified.getFullYear()}-{String(lastModified.getMonth() + 1).padStart(2, '0')}-{String(lastModified.getDate()).padStart(2, '0')}
                </p>
                <figure class="m-0 mb-8 flex justify-center bg-slate-50 rounded-lg overflow-hidden border border-slate-200">
                    {/* ★いただいたアイキャッチ画像を設定 */}
                    <Image src={imageUrl} alt="東近江エリアのゴルフ練習場 ジャンボ VS さくら" class="w-full h-auto object-cover max-h-[500px]" width={1200} height={675} format="webp" fetchpriority="high" />
                </figure>
            </header>

            <p>滋賀県東近江市で屋外の打ちっぱなしに行くなら、ゴルファーは必ずこの「究極の2択」で迷います。</p>
            <p><strong>「リバーサイドジャンボゴルフ（地元では『ジャンボ』や『リバーサイド』と呼ばれます）」か、「さくらゴルフ倶楽部」か。</strong></p>
            <p>はじめまして、「シガゴル」運営者の関（<a href="/about/">@seki</a>）です。<br>
            この2つの施設、実は<strong>「強み」と「ターゲット」が180度パキッと分かれている</strong>のをご存知ですか？どちらも素晴らしい練習場ですが、自分の目的（今日の気分）と違う方を選んでしまうと、少しもったいない思いをするかもしれません。</p>
            <p>この記事では、両方の施設の「有料会員」になって週に何度も通い詰めている私が、<strong>料金、パター・バンカーの質、さらには「駐車場の停めやすさ」や「客層」といったリアルすぎる本音</strong>で、2大巨頭を徹底比較します。</p>

            <h2 id="simulator" class="text-2xl md:text-3xl font-bold text-slate-800 mt-12 mb-6 border-b-2 border-slate-200 pb-2">【どっちが安い？】2大巨頭 専用料金シミュレーター</h2>
            <p>まずは気になる「料金」から。あなたの条件に合わせて、<strong>「ジャンボ」と「さくら」のどちらが、今日いくらで練習できるか</strong>を自動計算します。ポチポチ選んでみてください！</p>

            {/* ▼ 専用VSシミュレーターUI ▼ */}
            <div id="vs-price-simulator" class="not-prose bg-slate-800 p-4 md:p-6 rounded-2xl my-8 shadow-xl text-white"> 
                <h3 class="text-lg md:text-xl font-bold mb-6 text-center text-yellow-400 mt-0">
                    <i class="fa-solid fa-bolt mr-2"></i> ガチンコ料金シミュレーター
                </h3>
            
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div> 
                        <label class="font-bold text-slate-300 text-sm mb-1 block">① あなたの属性</label>
                        <select id="vs-user" class="w-full p-2.5 border border-slate-600 rounded-md bg-slate-700 text-white focus:ring-yellow-400 focus:border-yellow-400">
                            <option value="visitor_m" selected>一般（男性）</option>
                            <option value="visitor_f">一般（女性）</option>
                            <option value="junior">ジュニア（高校生以下）</option>
                        </select>
                    </div>
                    <div> 
                        <label class="font-bold text-slate-300 text-sm mb-1 block">② 会員ですか？（両施設共通として計算）</label>
                        <select id="vs-member" class="w-full p-2.5 border border-slate-600 rounded-md bg-slate-700 text-white focus:ring-yellow-400 focus:border-yellow-400">
                            <option value="false" selected>ビジター（非会員）</option>
                            <option value="true">メンバー（会員）</option>
                        </select>
                    </div>
                    <div> 
                        <label class="font-bold text-slate-300 text-sm mb-1 block">③ 練習に行く曜日</label>
                        <select id="vs-day" class="w-full p-2.5 border border-slate-600 rounded-md bg-slate-700 text-white focus:ring-yellow-400 focus:border-yellow-400">
                            <option value="weekday" selected>平日（月・金以外）</option>
                            <option value="ladies">平日（月・金）※レディースデー対象日</option>
                            <option value="weekend">土日祝</option>
                        </select>
                    </div>
                    <div> 
                        <label class="font-bold text-slate-300 text-sm mb-1 block">④ 時間帯</label>
                        <select id="vs-time" class="w-full p-2.5 border border-slate-600 rounded-md bg-slate-700 text-white focus:ring-yellow-400 focus:border-yellow-400">
                            <option value="morning">午前（9:00〜12:00）</option>
                            <option value="day" selected>日中（12:00〜17:00）</option>
                            <option value="night">夜間（17:00〜22:00）</option>
                        </select>
                    </div>
                </div>

                <div class="mb-6 bg-slate-700 p-4 rounded-lg">
                    <label class="font-bold text-slate-300 text-sm flex justify-between mb-2">
                        <span>⑤ 何球打ちますか？（さくらは2階席で計算）</span>
                        <span class="text-yellow-400 text-xl" id="vs-ball-display">150球</span>
                    </label>
                    <input type="range" id="vs-ball-slider" min="50" max="400" step="10" value="150" class="w-full h-2 bg-slate-600 rounded-lg appearance-none cursor-pointer accent-yellow-400">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    {/* ジャンボ 結果 */}
                    <div class="bg-blue-900 border-2 border-blue-500 rounded-xl p-4 text-center relative overflow-hidden">
                        <div class="absolute top-0 left-0 bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded-br-lg">ジャンボ</div>
                        <p class="text-sm text-blue-200 mt-4 mb-1">入場料等込みの最安値</p>
                        <p class="text-2xl md:text-3xl font-black text-white" id="vs-res-jumbo">¥---</p>
                        <p class="text-[10px] md:text-xs text-blue-300 mt-2 min-h-[2.5rem]" id="vs-note-jumbo"></p>
                    </div>
                    {/* さくら 結果 */}
                    <div class="bg-rose-900 border-2 border-rose-500 rounded-xl p-4 text-center relative overflow-hidden">
                         <div class="absolute top-0 left-0 bg-rose-600 text-white text-xs font-bold px-2 py-1 rounded-br-lg">さくら</div>
                        <p class="text-sm text-rose-200 mt-4 mb-1">入場料等込みの最安値</p>
                        <p class="text-2xl md:text-3xl font-black text-white" id="vs-res-sakura">¥---</p>
                        <p class="text-[10px] md:text-xs text-rose-300 mt-2 min-h-[2.5rem]" id="vs-note-sakura"></p>
                    </div>
                </div>
                <p class="text-xs text-center text-slate-400 mt-4">※あくまで目安です。女性・ジュニアの場合、さくらは打ち放題プランが自動適用されます。</p>
            </div>

            <h2 id="battle" class="text-2xl md:text-3xl font-bold text-slate-800 mt-16 mb-6 border-b-2 border-slate-200 pb-2">【徹底比較】ジャンボ vs さくら 5番勝負！</h2>
            <p>料金のイメージが湧いたところで、ここからは「質」「設備」「本音」で比較していきます。</p>

            <h3 class="text-xl font-bold text-slate-800 mt-10 mb-4 flex items-center gap-2">
                <span class="bg-slate-800 text-white w-8 h-8 flex items-center justify-center rounded-full text-sm">1</span> 
                料金・コスパ対決
            </h3>
            <p><strong>【ジャンボ】サービスタイムとポイント還元が熱い</strong><br>
            ジャンボは毎朝9時〜12時まで「1球7円」のサービスタイムがあります。また、プリペイドカード購入時のポイント還元率が非常に高く、会員になって通い詰めるほどお得になる「本格派への投資」システムです。（会員になれば平日・土日祝問わず一律1球9円になります！）</p>
            <p><strong>【さくら】女性とジュニアへの優遇が“バグ”レベル</strong><br>
            さくらのコスパは異次元です。女性とジュニアは「入場料無料」かつ「1時間515円〜の打ち放題」がいつでも使えます。さらに、女性・ジュニアは<strong>アプローチ練習場が60分無料</strong>という、お店の善意による本当にありがたい優遇サービスがあります。打席練習の前後でしっかりショートゲームも磨けるのが最高です。</p>
            <div class="bg-slate-100 p-4 rounded-lg text-sm mb-6 border border-slate-300">
                <p class="m-0 text-center font-bold">🏆 料金対決の勝者は…<br>
                <span class="text-rose-600 text-lg">【さくら】（※特に女性・初心者の場合）</span></p>
            </div>

            <p class="text-sm text-slate-600 mt-2 mb-8 bg-slate-50 p-3 rounded border border-slate-200">
                👉 <strong>【もっと安さを追求したい方へ】</strong><br>
                東近江市だけでなく、お隣の近江八幡エリアも含めた「最安値」を知りたい方は、<a href="/articles/comparison/omi-pricerank/" class="text-blue-600 font-bold hover:underline">近江八幡・東近江の安い練習場5選（料金比較シミュレーター付）</a>もあわせてご覧ください。
            </p>

            <h3 class="text-xl font-bold text-slate-800 mt-10 mb-4 flex items-center gap-2">
                <span class="bg-slate-800 text-white w-8 h-8 flex items-center justify-center rounded-full text-sm">2</span> 
                練習環境（打席）対決
            </h3>
            <p><strong>【ジャンボ】リニューアル済みの極上マットと的確なヤード表示</strong><br>
            ジャンボは2025年に打席をリニューアルし、マットがふかふかでノーストレス。さらに、各打席からターゲットまでの正確な実測ヤード数が表示されており、本番さながらの精度の高い練習が可能です。</p>
            <figure class="my-4 not-prose">
                <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_9012.png" alt="リニューアルされたジャンボの極上マット" class="w-full aspect-video object-cover rounded-lg border border-slate-200 shadow-sm" width={800} height={450} format="webp" />
                <figcaption class="text-center text-sm text-slate-500 mt-2">新調されたジャンボの打席。マットの質が高く打ちやすいです。</figcaption>
            </figure>

            <p><strong>【さくら】初心者の「恥ずかしい」を消し去る2階席</strong><br>
            さくらは設備こそ少し年季が入っていますが、2階の奥に<strong>「初心者優先スペース」</strong>があります。</p>
            <figure class="my-4 not-prose">
                 <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/sakura_gc/gallery/5.png" alt="さくらゴルフ倶楽部の初心者優先打席" class="w-full aspect-video object-cover rounded-lg border border-slate-200 shadow-sm" width={800} height={450} format="webp" />
                 <figcaption class="text-center text-sm text-slate-500 mt-2">横から見たさくらの初心者優先スペース。独立した空間で安心です。</figcaption>
            </figure>
            <p>この高いパーテーションのおかげで、隣からの視線が完全に遮断されます。「空振りしたらどうしよう…」というゴルフデビュー直後の不安を、これほど解消してくれる場所は他にありません。夏場は冷房も効いていて快適です。</p>
            <div class="bg-slate-100 p-4 rounded-lg text-sm mb-6 border border-slate-300">
                <p class="m-0 text-center font-bold">🏆 練習環境対決の勝者は…<br>
                <span class="text-slate-700">【本気で上達ならジャンボ】 / 【気楽に打つならさくら】の引き分け！</span></p>
            </div>

            <p class="text-sm text-slate-600 mt-2 mb-8 bg-slate-50 p-3 rounded border border-slate-200">
                👉 <strong>【これからゴルフを始める方へ】</strong><br>
                「周りの目が気にならない場所が良い」「レッスンを受けてみたい」という初心者の方は、<a href="/articles/comparison/omi-lesson/" class="text-blue-600 font-bold hover:underline">近江八幡・東近江の初心者向け・レッスン比較まとめ</a>も要チェックです。
            </p>

            <h3 class="text-xl font-bold text-slate-800 mt-10 mb-4 flex items-center gap-2">
                <span class="bg-slate-800 text-white w-8 h-8 flex items-center justify-center rounded-full text-sm">3</span> 
                ショートゲーム（アプローチ・バンカー）対決
            </h3>
            <p><strong>【ジャンボ】東近江で一択！神パター＆本格バンカー</strong></p>
            
            {/* ★画像を綺麗なグリッドとアスペクト比で並べる */}
            <div class="grid md:grid-cols-2 gap-4 my-4 not-prose">
                 <figure class="m-0">
                     <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_6450 2.jpg" alt="ジャンボの無料パターグリーン" class="w-full aspect-video object-cover rounded-lg shadow-sm border border-slate-200" width={600} height={337} format="webp" />
                 </figure>
                 <figure class="m-0">
                     <Image src="https://storage.googleapis.com/shigagolf-e31e6.firebasestorage.app/practice_ranges/riverside_jumbo/gallery/IMG_6402.jpg" alt="ジャンボの本格バンカー" class="w-full aspect-video object-cover rounded-lg shadow-sm border border-slate-200" width={600} height={337} format="webp" />
