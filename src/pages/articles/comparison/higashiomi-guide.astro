    {/* =======================================================
        専用 VS料金シミュレーター JavaScript
    ======================================================== */}
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const simulator = document.getElementById('vs-price-simulator');
        if (!simulator) return;

        const userSel = document.getElementById('vs-user');
        const memSel = document.getElementById('vs-member');
        const daySel = document.getElementById('vs-day');
        const timeSel = document.getElementById('vs-time');
        const ballSlider = document.getElementById('vs-ball-slider');
        const ballDisplay = document.getElementById('vs-ball-display');

        const resJumbo = document.getElementById('vs-res-jumbo');
        const noteJumbo = document.getElementById('vs-note-jumbo');
        const resSakura = document.getElementById('vs-res-sakura');
        const noteSakura = document.getElementById('vs-note-sakura');

        function calculate() {
            const user = userSel.value;
            const isMem = memSel.value === "true";
            const day = daySel.value; // weekday, ladies, weekend
            const time = timeSel.value; // morning(9-12), day(12-17), night(17-22)
            const balls = parseInt(ballSlider.value);
            ballDisplay.textContent = `${balls}球`;

            const isFemale = (user === 'visitor_f');
            const isJunior = (user === 'junior');
            const reqHours = balls <= 150 ? 1 : (balls <= 250 ? 2 : 3);

            // --- ジャンボの計算 ---
            // 入場料: 会員200, ビジター400
            let jEntry = isMem ? 200 : 400;
            // 単価: 基本は9円（会員なら一律9円）
            let jBallPrice = 9;
            // ビジターで土日祝なら10円
            if(!isMem && day === 'weekend') {
                jBallPrice = 10;
            }
            // 午前中(9-12時)は誰でもサービスタイムで7円
            if(time === 'morning') {
                jBallPrice = 7;
            }
            // レディースデー(月金の9-17時)の女性なら6円
            if(isFemale && day === 'ladies' && time !== 'night') {
                jBallPrice = 6;
            }
            
            let jTotal = jEntry + (jBallPrice * balls);
            resJumbo.textContent = `¥${jTotal.toLocaleString()}`;
            noteJumbo.innerHTML = `入場料${jEntry}円 + 単価${jBallPrice}円`;

            // --- さくらの計算 ---
            // 入場料: 女性・ジュニア・会員は0円。ビジターは平日280, 土日320
            let sEntry = 0;
            if(!isMem && !isFemale && !isJunior) {
                sEntry = (day === 'weekend') ? 320 : 280;
            }

            // 単価打ち計算 (ざっくり2階席基準)
            let sBallPrice = 8;
            if(time === 'morning' || time === 'day') {
                sBallPrice = (day === 'weekend') ? 9 : 7;
            } else if (time === 'night') {
                sBallPrice = (day === 'weekend') ? 9 : 8;
            }
            if(isMem) sBallPrice -= 1; // 会員は1円引き
            let sTotalNormal = sEntry + (sBallPrice * balls);

            // 打ち放題の計算
            let sTotalUnlimited = 99999;
            let uName = "";
            if (isFemale || isJunior) {
                if(reqHours === 1) { sTotalUnlimited = 515; uName="1h打ち放題"; }
                else if(reqHours === 2) { sTotalUnlimited = 1030; uName="2h打ち放題"; }
                else { sTotalUnlimited = 1545; uName="3h打ち放題"; }
            } else if (isMem) {
                if(reqHours <= 2) { sTotalUnlimited = 1030; uName="2h打ち放題"; }
                else { sTotalUnlimited = 1545; uName="3h打ち放題"; }
            } else {
                sTotalUnlimited = (day === 'weekend') ? 2060 : 1854; 
                uName="3h打ち放題";
            }

            // 安い方を採用
            if (sTotalUnlimited <= sTotalNormal) {
                resSakura.textContent = `¥${sTotalUnlimited.toLocaleString()}`;
                noteSakura.innerHTML = `<span class="text-yellow-300 font-bold">※${uName}適用</span><br>(単価計算だと¥${sTotalNormal.toLocaleString()})`;
            } else {
                resSakura.textContent = `¥${sTotalNormal.toLocaleString()}`;
                noteSakura.innerHTML = `入場料${sEntry}円 + 単価${sBallPrice}円`;
            }
        }

        [userSel, memSel, daySel, timeSel].forEach(el => el.addEventListener('change', calculate));
        ballSlider.addEventListener('input', calculate);
        calculate();
    });
    </script>
</BaseLayout>